---
import type { ToolOutput } from "../types";
import {
  escapeHtml,
  parseDiff,
  parseFileRead,
  formatBashTerminal,
} from "../render";

interface Props {
  tool: string;
  args: string;
  output: ToolOutput | null;
  index: number;
}

const { tool, args, output, index } = Astro.props;

// [LAW:dataflow-not-control-flow] One component, one dispatch on output.kind.
// Each kind has its own body template; CSS keys off `data-output-kind` on the
// frame. No layout decisions live in CSS-only — every visual difference is
// driven by the typed value flowing in.

const kind = output?.kind ?? "generic";

// Path-like tools (Read, Update) show their arg in the header. Bash's arg is
// the command, which goes in the body alongside its output.
const showHeaderArgs =
  (kind === "diff" || kind === "file-read") && args.trim().length > 0;

const diffParsed = kind === "diff" && output ? parseDiff(output.text) : null;
const fileParsed =
  kind === "file-read" && output ? parseFileRead(output.text) : null;
const terminalText =
  kind === "terminal" && output
    ? formatBashTerminal(args, output.text)
    : null;

// For tool calls with no recognized output (e.g. "Called X-mcp (ctrl+o)"),
// just show the header.
const hasBody = output !== null;

// Args block only renders for the generic fallback path, when args is non-empty.
const showGenericArgsBlock =
  kind === "generic" && args.trim().length > 0;
---

<article class="bubble bubble-tool-call" data-kind="tool-call" data-tool={tool} data-index={index}>
  <header class="tool-header">
    <span class="tool-arrow" aria-hidden="true">▸</span>
    <span class="tool-name">{tool}</span>
    {showHeaderArgs && <span class="tool-path">{args.trim()}</span>}
  </header>

  {showGenericArgsBlock && (
    <figure class="tool-output-frame" data-output-kind="args">
      <span class="output-kind-pill" aria-hidden="true">args</span>
      <pre class="code-block tool-output"><code set:html={escapeHtml(args)} /></pre>
    </figure>
  )}

  {kind === "terminal" && hasBody && terminalText !== null && (
    <figure class="tool-output-frame" data-output-kind="terminal">
      <span class="output-kind-pill" aria-hidden="true">terminal</span>
      <pre class="code-block tool-output"><code set:html={escapeHtml(terminalText)} /></pre>
    </figure>
  )}

  {kind === "diff" && diffParsed && (
    <figure class="tool-output-frame" data-output-kind="diff">
      {diffParsed.summary && (
        <span class="output-kind-pill" aria-hidden="true">{diffParsed.summary}</span>
      )}
      <div class="diff-block">
        {diffParsed.lines.map((line) => (
          <div class={`diff-line diff-${line.kind}`}>
            <span class="diff-lineno">{line.lineNo ?? ""}</span>
            <span class="diff-marker" aria-hidden="true">{
              line.kind === "added" || line.kind === "cont-added"
                ? "+"
                : line.kind === "removed" || line.kind === "cont-removed"
                ? "-"
                : " "
            }</span>
            <span class="diff-content" set:html={escapeHtml(line.content)} />
          </div>
        ))}
      </div>
    </figure>
  )}

  {kind === "file-read" && fileParsed && (
    <figure class="tool-output-frame" data-output-kind="file-read">
      {fileParsed.summary && (
        <span class="output-kind-pill" aria-hidden="true">{fileParsed.summary}</span>
      )}
      <div class="file-block">
        {fileParsed.lines.map((line) => (
          <div class="file-line">
            <span class="file-lineno">{line.lineNo ?? ""}</span>
            <span class="file-content" set:html={escapeHtml(line.content)} />
          </div>
        ))}
      </div>
    </figure>
  )}

  {kind === "generic" && hasBody && (
    <figure class="tool-output-frame" data-output-kind="generic">
      <span class="output-kind-pill" aria-hidden="true">output</span>
      <pre class="code-block tool-output"><code set:html={escapeHtml(output!.text)} /></pre>
    </figure>
  )}
</article>
