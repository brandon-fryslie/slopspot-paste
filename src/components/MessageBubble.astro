---
import type { Role } from "../types";
import { renderMarkdown } from "../render";

interface Props {
  role: Role;
  content: string;
  index: number;
}

const { role, content, index } = Astro.props;

// [LAW:dataflow-not-control-flow] One component for all three roles. Role
// drives class/label/alignment as a value, never as separate components.
const roleLabel: Record<Role, string> = {
  user: "User",
  assistant: "Assistant",
  system: "System",
};

const html = renderMarkdown(content);
---

<article class={`bubble bubble-${role}`} data-kind="message" data-role={role} data-index={index}>
  <header class="bubble-role">
    <span class={`role-dot role-dot-${role}`} aria-hidden="true"></span>
    <span class="role-name">{roleLabel[role]}</span>
  </header>
  <div class="bubble-body" set:html={html} />
</article>
