---
import type { Turn } from "../types";
import { renderMarkdown } from "../render";

interface Props {
  turn: Turn;
  index: number;
}

const { turn, index } = Astro.props;

// [LAW:dataflow-not-control-flow] One Bubble component handles every role.
// Role drives class/label/alignment as a *value*, not as separate components.
const roleLabel: Record<Turn["role"], string> = {
  user: "User",
  assistant: "Assistant",
  system: "System",
};

const html = renderMarkdown(turn.content);
---

<article class={`bubble bubble-${turn.role}`} data-index={index}>
  <header class="bubble-role">
    <span class={`role-dot role-dot-${turn.role}`} aria-hidden="true"></span>
    <span class="role-name">{roleLabel[turn.role]}</span>
  </header>
  <div class="bubble-body" set:html={html} />
</article>
