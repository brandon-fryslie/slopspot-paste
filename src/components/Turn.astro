---
import type { Turn } from "../types";
import MessageBubble from "./MessageBubble.astro";
import ToolCallBubble from "./ToolCallBubble.astro";
import InsightBubble from "./InsightBubble.astro";
import TurnSummary from "./TurnSummary.astro";

interface Props {
  turn: Turn;
  index: number;
}

const { turn, index } = Astro.props;

// [LAW:single-enforcer] All kind-dispatch lives here. Pages don't switch on
// kind; they map over turns and render <Turn />. Adding a new kind = adding
// one case here and one component file.
---

{turn.kind === "message" && (
  <MessageBubble role={turn.role} content={turn.content} index={index} />
)}
{turn.kind === "tool-call" && (
  <ToolCallBubble tool={turn.tool} args={turn.args} output={turn.output} index={index} />
)}
{turn.kind === "insight" && (
  <InsightBubble content={turn.content} index={index} />
)}
{turn.kind === "turn-summary" && (
  <TurnSummary text={turn.text} index={index} />
)}
