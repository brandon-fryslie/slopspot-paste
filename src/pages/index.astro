---
import Base from "../layouts/Base.astro";
import { MAX_PASTE_LABEL, SOURCE_LABEL, TEXT_ARM_KINDS } from "../types";

export const prerender = false;

// [LAW:no-silent-fallbacks] The no-JS <form> POST path cannot fetch URLs (the
// url arm is a JS-only JSON path; the server rejects it on the form path). So the
// server-rendered fallback offers only the text kinds that path can fulfill —
// every SourceKind that is not a Provider. With JS on, the editor (mountEditor)
// replaces this entirely — its import box rebuilds the dropdown from
// store.detected and offers the generic "url" fetch arm for any link.
// [LAW:one-source-of-truth] TEXT_ARM_KINDS IS the non-Provider subset; no second
// hand-rolled filter to drift from it.
const fallbackKinds = TEXT_ARM_KINDS;
---

<Base title="slopspot · paste — share LLM conversations">
  <section class="hero">
    <h1>Share an LLM conversation, readably.</h1>
    <p class="hero-sub">
      Paste a transcript, edit it into clean blocks, and get a link. We render it
      as a chat — bubbles, code blocks, markdown. Anonymous. Expires after
      30 days.
    </p>
  </section>

  <!-- [LAW:no-ambient-temporal-coupling] One empty container; lit-html owns its
       entire subtree. mountEditor() renders into it after this module script
       runs at end of body, so #editor-root is guaranteed to exist first. We do
       not toggle visibility based on "did mount run" — the browser decides what
       renders from JS presence alone (editor here, <noscript> form below). -->
  <div id="editor-root"></div>

  <!-- [LAW:no-silent-fallbacks] The JS-disabled fallback. Native <noscript>
       semantics — not a script hiding/showing nodes — mean JS-off users get the
       static form and JS-on users get the editor, with no double UI and no
       flash. External API callers POST /api/paste directly and never render
       this. Text arms only; claude-share needs the JSON submit path. -->
  <noscript>
    <form class="paste-form" action="/api/paste" method="post">
      <div class="source-row">
        <label for="source" class="source-label">Source format</label>
        <select id="source" name="source" class="source-select">
          {fallbackKinds.map((k) => (
            <option value={k}>{SOURCE_LABEL[k]}</option>
          ))}
        </select>
      </div>
      <label for="content" class="visually-hidden">Conversation text</label>
      <textarea
        id="content"
        name="content"
        rows="18"
        required
        placeholder={`Paste a conversation. Recognized formats:

## User
What's the time complexity of quicksort?

## Assistant
Average O(n log n), worst-case O(n²).

— or "You said:" / "ChatGPT said:" — or "Human:" / "Assistant:" —
— or a Claude Code transcript (❯ / ⏺ / ⎿ markers) —`}
      ></textarea>
      <div class="form-row">
        <button type="submit" class="btn-primary">Share it</button>
        <span class="form-hint">Up to {MAX_PASTE_LABEL}. No edit — expires in 30 days.</span>
      </div>
    </form>
  </noscript>

  <script>
    // [LAW:effects-at-boundaries] The entire client wiring: mount the editor.
    // mountEditor does the must() root lookup, builds the store with real IO
    // (fetch + navigation), and drives lit-html via mobx autorun. The old inline
    // detectSources/dropdown script is gone — that logic now lives in the store.
    import { mountEditor } from "../editor/mount";
    mountEditor();
  </script>
</Base>
