---
import Base from "../layouts/Base.astro";
import { SOURCE_KINDS, SOURCE_LABEL } from "../types";

export const prerender = false;
---

<Base title="slopspot · paste — share LLM conversations">
  <section class="hero">
    <h1>Share an LLM conversation, readably.</h1>
    <p class="hero-sub">
      Paste a transcript below. We render it as a chat — bubbles, code blocks,
      markdown — and give you a link. Anonymous. Auto-deletes after 30 days.
    </p>
  </section>

  <form id="paste-form" class="paste-form" action="/api/paste" method="post">
    <div class="source-row">
      <label for="source" class="source-label">Source format</label>
      <select id="source" name="source" class="source-select">
        <option value="">Auto-detect</option>
        {SOURCE_KINDS.map((k) => (
          <option value={k}>{SOURCE_LABEL[k]}</option>
        ))}
      </select>
    </div>
    <label for="content" class="visually-hidden">Conversation text</label>
    <textarea
      id="content"
      name="content"
      rows="18"
      required
      placeholder={`Paste a conversation. Recognized formats:

## User
What's the time complexity of quicksort?

## Assistant
Average O(n log n), worst-case O(n²).

— or "You said:" / "ChatGPT said:" — or "Human:" / "Assistant:" —
— or a Claude Code transcript (❯ / ⏺ / ⎿ markers) —`}
    ></textarea>
    <div class="form-row">
      <button type="submit" class="btn-primary">Share it</button>
      <span class="form-hint">Up to ~256 KB. No edit, no delete — disappears in 30 days.</span>
    </div>
    <p id="form-error" class="form-error" role="alert" hidden></p>
  </form>

  <script is:inline>
    // [LAW:dataflow-not-control-flow] One submit path. The source field's
    // value is either an empty string (Auto-detect → omit `source`, server
    // uses parseAuto) or a SourceKind (server uses parseInput). The branch
    // lives in the constructed body shape, not in two code paths.
    const form = document.getElementById("paste-form");
    const err = document.getElementById("form-error");
    const sourceEl = document.getElementById("source");
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      err.hidden = true;
      const btn = form.querySelector("button[type=submit]");
      btn.disabled = true;
      btn.textContent = "Sharing…";
      try {
        const kind = sourceEl.value;
        const content = form.content.value;
        const body = kind === "" ? { content } : { source: { kind, content } };
        const res = await fetch("/api/paste", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(body),
        });
        const result = await res.json();
        if (!res.ok || !result.slug) {
          throw new Error(result.error || "Server error");
        }
        window.location.assign("/" + result.slug);
      } catch (e2) {
        err.textContent = e2.message;
        err.hidden = false;
        btn.disabled = false;
        btn.textContent = "Share it";
      }
    });
  </script>
</Base>
