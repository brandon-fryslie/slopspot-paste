---
import { env } from "cloudflare:workers";
import Base from "../../../layouts/Base.astro";
import { loadViewablePaste } from "../../../loadPaste";
import { deriveDiffColumn, diffOutcome, renderDiffRow, renderColumnHtml } from "../../../diff";

export const prerender = false;

// [LAW:effects-at-boundaries] The two KV reads are the only IO — performed here at the
// route boundary, in parallel, once per slug. loadViewablePaste is the ONE visibility
// gate [LAW:single-enforcer]: a hidden/expired paste is refused on each side exactly as
// it is on /<slug>, so a diff can never leak a paste that is gone. Everything after is a
// pure projection of the two PasteLoads (src/diff.ts).
const { a, b } = Astro.params;
const now = Date.now();
const [loadA, loadB] = await Promise.all([
  loadViewablePaste(env.PASTES, a, now),
  loadViewablePaste(env.PASTES, b, now),
]);

// [LAW:dataflow-not-control-flow] The outcome is a VALUE naming its display mode: an
// `aligned` diff (both sides loaded — paired rows), a `one-sided` view (exactly one side
// loaded — the present column beside the absent side's status), or a `fail` response (only
// when NEITHER loaded), carrying both reasons. The template draws the mode; it never
// re-decides which one applies.
const left = deriveDiffColumn(a ?? "", loadA);
const right = deriveDiffColumn(b ?? "", loadB);
const outcome = diffOutcome(left, right);
if (outcome.kind === "fail") {
  return new Response(outcome.message, { status: outcome.status });
}

// The two columns for the one-sided layout (substrate independent-column markup): exactly
// one is a shown conversation, the other an honest status box. Unused in aligned mode.
const columns = outcome.kind === "one-sided" ? [outcome.left, outcome.right] : [];
// The pre-rendered aligned rows (each cell html, or null where this side has a gap), so the
// template stays presentational. Empty in one-sided mode (the two column heads are read off
// the narrowed `outcome` directly in the aligned branch below).
const rows = outcome.kind === "aligned" ? outcome.rows.map(renderDiffRow) : [];
---

<Base title="Side-by-side · slopspot paste">
  <section class="conversation-header diff-header">
    <h1>Side-by-side comparison</h1>
    <p class="conversation-meta">
      <span>Two shared conversations, compared</span>
    </p>
  </section>

  {outcome.kind === "aligned" ? (
    // [LAW:composability] The aligned diff: two column heads over a stack of paired rows.
    // Each row is a 2-up grid; a cell carries one spine node's html (drawn by the ONE
    // renderer at topLevel:false) or is an empty gap opposite its counterpart. Prompts that
    // pair land on the same row; a prompt present on one side only opens a visible gap on
    // the other [LAW:no-silent-failure] — never a silent shift of everything after it.
    <div class="diff-aligned">
      <div class="diff-row diff-heads">
        {[outcome.left, outcome.right].map((head) => (
          <header class="diff-column-header diff-cell" data-platform={head.platform} data-slug={head.slug}>
            <h2 class="diff-column-title"><a href={`/${head.slug}`}>{head.title}</a></h2>
            <p class="conversation-meta">
              {head.platformLabel && <span class="platform-badge">{head.platformLabel}</span>}
              {head.platformLabel && <span aria-hidden="true">·</span>}
              <span>{head.turnCount} turns</span>
            </p>
          </header>
        ))}
      </div>
      {rows.map((row) => (
        <div class="diff-row">
          <div
            class="diff-cell conversation"
            data-platform={outcome.left.platform}
            data-gap={row.left === null ? "true" : undefined}
            aria-label={`Conversation ${outcome.left.slug}`}
            set:html={row.left ?? ""}
          />
          <div
            class="diff-cell conversation"
            data-platform={outcome.right.platform}
            data-gap={row.right === null ? "true" : undefined}
            aria-label={`Conversation ${outcome.right.slug}`}
            set:html={row.right ?? ""}
          />
        </div>
      ))}
    </div>
  ) : (
    // One-sided: exactly one side loaded. The substrate independent-column layout — the
    // present conversation beside the absent side's honest status box [LAW:no-silent-failure].
    // There is no second dialogue to align against, so nothing is paired.
    <div class="diff-columns">
      {columns.map((col) => (
        <div class="diff-column" data-platform={col.ok ? col.platform : undefined} data-slug={col.slug}>
          {col.ok ? (
            <Fragment>
              <header class="diff-column-header">
                <h2 class="diff-column-title"><a href={`/${col.slug}`}>{col.title}</a></h2>
                <p class="conversation-meta">
                  {col.platformLabel && <span class="platform-badge">{col.platformLabel}</span>}
                  {col.platformLabel && <span aria-hidden="true">·</span>}
                  <span>{col.turnCount} turns</span>
                </p>
              </header>
              <section
                class="conversation"
                aria-label={`Conversation ${col.slug}`}
                data-slug={col.slug}
                set:html={renderColumnHtml(col.view)}
              />
            </Fragment>
          ) : (
            <div class="diff-column-missing" role="status">
              <p class="diff-column-missing-slug">{col.slug}</p>
              <p class="diff-column-missing-msg">{col.message}</p>
            </div>
          )}
        </div>
      ))}
    </div>
  )}
</Base>
