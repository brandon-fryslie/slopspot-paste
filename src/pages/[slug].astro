---
import { env } from "cloudflare:workers";
import Base from "../layouts/Base.astro";
import Bubble from "../components/Bubble.astro";
import { getConversation } from "../storage";
import { isValidSlug } from "../slug";

export const prerender = false;

const { slug } = Astro.params;

// [LAW:dataflow-not-control-flow] Same handler shape: validate slug → fetch →
// render. Variability is the conversation value or its absence.
if (!slug || !isValidSlug(slug)) {
  return new Response("Not found", { status: 404 });
}

const conversation = await getConversation(env.PASTES, slug);

if (!conversation) {
  // [LAW:single-enforcer] Expiry shows up here as plain absence, because the
  // KV layer already removed the key. No "isExpired" check anywhere.
  return new Response("This paste has expired or never existed.", { status: 404 });
}

const title = conversation.title ?? "Shared conversation";
const expiresIn = Math.max(0, Math.ceil((conversation.expiresAt - Date.now()) / 86_400_000));
---

<Base title={`${title} · slopspot paste`}>
  <section class="conversation-header">
    <h1>{title}</h1>
    <p class="conversation-meta">
      <span>{conversation.turns.length} turns</span>
      <span aria-hidden="true">·</span>
      <span>Disappears in {expiresIn} {expiresIn === 1 ? "day" : "days"}</span>
    </p>
  </section>

  <section class="conversation" aria-label="Conversation">
    {conversation.turns.map((turn, i) => <Bubble turn={turn} index={i} />)}
  </section>
</Base>
