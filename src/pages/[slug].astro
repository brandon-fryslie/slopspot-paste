---
import { env } from "cloudflare:workers";
import Base from "../layouts/Base.astro";
import { renderDialogueHtml } from "../renderDialogue";
import { deriveViewableDialogue } from "../overlay";
import { deriveSpineOutline } from "../spineOutline";
import { extractArtifacts } from "../artifacts";
import { renderCodeExportControl } from "../codeExport";
import { loadViewablePaste } from "../loadPaste";
import { derivePasteMeta, sourceUrlOf, viewLifetime } from "../types";

export const prerender = false;

const { slug } = Astro.params;

// [LAW:single-enforcer] loadViewablePaste is the one gate resolving a public paste
// from a slug (bad slug / missing → 404, soft-deleted or expired → 410) — the SAME
// gate the single-turn card route uses, so a hidden paste cannot leak on one surface
// while it is gone on the other. [LAW:dataflow-not-control-flow] its result is a
// value: the conversation or the exact response to emit.
const load = await loadViewablePaste(env.PASTES, slug, Date.now());
if (!load.ok) {
  return new Response(load.message, { status: load.status });
}
const conversation = load.conversation;

// [LAW:one-source-of-truth] Title, theme platform, and label are the display-meta
// projection derived once in derivePasteMeta — the SAME values the single-turn card
// and embed frame show. The body attribute themes the page via CSS variables; the
// label names the platform in the meta line (null for a generic platform, so absence
// of provenance renders as absence).
const { title, platform, platformLabel } = derivePasteMeta(conversation);
// [LAW:dataflow-not-control-flow] Both lifetime cases produce a meta string
// through one match — a pinned paste reads "Never disappears", never a forgotten
// branch that lies "Disappears in 0 days".
const life = viewLifetime(conversation.lifetime, Date.now());
const lifetimeLabel =
  life.kind === "pinned"
    ? "Never disappears"
    : `Disappears in ${life.days} ${life.days === 1 ? "day" : "days"}`;
const origin = conversation.origin;
// [LAW:one-source-of-truth] The original-source link is a projection of the
// captured origin (sourceUrlOf), never a second stored field. null for every
// origin without an upstream URL — text pastes, editor-authored, legacy — which
// renders as nothing below, not a placeholder ([LAW:dataflow-not-control-flow]:
// the absence is a value the template skips, not a branch that conditionally
// builds a header). The URL was validated as a claude.ai/share link at ingest.
const sourceUrl = sourceUrlOf(origin);

// [LAW:single-enforcer] One oEmbed discovery <link> in this paste's head is the entry
// point that makes a bare paste URL auto-embeddable: a consumer that does oEmbed
// discovery (WordPress, Notion, Discourse) reads the head, finds this, and calls the
// endpoint — no one has to know /api/oembed exists. [LAW:one-source-of-truth] it points
// at the SAME endpoint, addressed by the same absolute paste URL parsePasteRef reduces
// to a slug, so discovery cannot drift from what the endpoint serves. We advertise ONLY
// application/json+oembed because the endpoint serves only JSON — it returns 501 for xml
// on purpose — and its 200 Content-Type is literally this type, so the link's type and
// the served type agree by construction, never a text/xml+oembed link that would lie
// about a format we don't serve [FRAMING:representation]. Both URLs are absolute
// (Astro.url.origin — the SAME request-derived origin the endpoint computes from
// new URL(request.url).origin) because consumers fetch cross-origin. The paste URL is
// percent-encoded into the url= param so a consumer decodes back exactly the absolute
// paste URL. The link's title is the same derivePasteMeta projection the page and
// endpoint show, never a second title.
const oembedHref = `${Astro.url.origin}/api/oembed?url=${encodeURIComponent(`${Astro.url.origin}/${slug}`)}&format=json`;

// [LAW:one-source-of-truth] Derive the nested Dialogue ONCE, then take two disposable
// projections of it: the rendered conversation HTML and the topic outline. Both are
// pure functions of the same stored original — nothing here is persisted, and a paste
// with no turns yields an empty outline that renders nothing (a value, not a branch
// that special-cases empty).
// [LAW:single-enforcer] The one viewable-spine derivation: turns → dialogue → apply the
// authored overlay. Both the rendered conversation AND the topic outline read this one
// `dialogue`, so a redacted turn cannot leak through the outline label either.
const dialogue = deriveViewableDialogue(conversation);
const outline = deriveSpineOutline(dialogue);

// [LAW:one-source-of-truth] Code artifacts are a THIRD projection of the SAME viewable
// `dialogue` the renderer and outline read — extracted from its already-redacted nodes,
// never the raw stored turns, so "Copy all code" copies exactly what the reader sees and
// a redacted secret cannot leak through it [LAW:single-enforcer]. The control renders to
// nothing when the conversation carries no code (a value, not a special-cased branch).
const codeExportHtml = renderCodeExportControl(extractArtifacts(dialogue.map((d) => d.node)));
---

<Base title={`${title} · slopspot paste`} platform={platform}>
  <link
    slot="head"
    rel="alternate"
    type="application/json+oembed"
    href={oembedHref}
    title={title}
  />
  <section class="conversation-header">
    <h1>{title}</h1>
    <p class="conversation-meta">
      {platformLabel && <span class="platform-badge">{platformLabel}</span>}
      {platformLabel && <span aria-hidden="true">·</span>}
      <span>{conversation.turns.length} turns</span>
      <span aria-hidden="true">·</span>
      <span>{lifetimeLabel}</span>
    </p>
    {sourceUrl && (
      <p class="source-origin">
        <a href={sourceUrl} target="_blank" rel="noopener noreferrer">
          View original on claude.ai ↗
        </a>
      </p>
    )}
  </section>

  {/*
    [LAW:effects-at-boundaries] The "Compare with…" control mints a /diff/<this>/<other>
    URL and navigates — no new server work. It carries no slug of its own: the client script
    reads this paste's slug from the one server-rendered data-slug on .conversation
    [LAW:one-source-of-truth], and validates the entered reference before navigating so a typo
    is a legible inline error, not a silent 404 round-trip [LAW:no-silent-failure].
    [LAW:dataflow-not-control-flow] display:none until the script confirms it can act and adds
    body.compare-ready (mirroring the copy pills): with JavaScript disabled the reader's page
    is unchanged — the form is never a dead control that can't perform its one effect.
  */}
  <section class="compare">
    <form class="compare-form">
      <label class="compare-label" for="compare-input">Compare with another paste</label>
      <span class="compare-field">
        <input class="compare-input" id="compare-input" type="text" autocomplete="off"
          spellcheck="false" placeholder="paste slug or link…" aria-describedby="compare-error" />
        <button class="mono-pill compare-go" type="submit">Compare</button>
      </span>
      <p class="form-error compare-error" id="compare-error" role="alert" hidden></p>
    </form>
  </section>

  <script>
    // [LAW:effects-at-boundaries] The Compare-with control is pure client navigation: its
    // ONLY effect is location.assign at the submit boundary. parsePasteRef (src/slug.ts) is
    // the pure validator — the SAME slug law the /diff route's loader gates on
    // [LAW:one-source-of-truth] — so a typo is caught inline here rather than round-tripping
    // to a 404 [LAW:no-silent-failure]. Progressive enhancement like the copy pills: the
    // section is display:none until this script adds body.compare-ready, so a no-JS reader's
    // page is unchanged and never carries a dead control.
    import { parsePasteRef } from "../slug";

    // [LAW:no-silent-failure] The .compare-form and .conversation sections are
    // unconditional template invariants (both server-rendered every load), so a missing
    // one is a broken template, not an optional feature — throw loudly like the sibling
    // scripts here rather than silently leaving Compare hidden [LAW:no-defensive-null-guards].
    const form = document.querySelector<HTMLFormElement>(".compare-form");
    const conversation = document.querySelector<HTMLElement>(".conversation");
    if (!form || !conversation) throw new Error("required .compare-form or .conversation section missing");
    const input = form.querySelector<HTMLInputElement>(".compare-input");
    const error = form.querySelector<HTMLElement>(".compare-error");
    if (!input || !error) throw new Error("compare form is missing its input or error slot");

    // [LAW:one-source-of-truth] This paste's slug is read from the one server-rendered
    // data-slug on .conversation — never re-derived from location.pathname.
    const thisSlug = conversation.dataset.slug ?? "";

    // [LAW:dataflow-not-control-flow] reason → message is a total map over the two
    // rejection arms: the pure core owns "is it a slug", the boundary owns the copy.
    const messageFor = (reason: "empty" | "malformed"): string =>
      reason === "empty"
        ? "Enter a paste slug or link to compare with."
        : "That doesn't look like a valid paste slug or link.";

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      const ref = parsePasteRef(input.value);
      if (ref.ok) {
        // [LAW:effects-at-boundaries] the sole effect: navigate to the substrate diff route.
        window.location.assign("/diff/" + thisSlug + "/" + ref.slug);
      } else {
        error.textContent = messageFor(ref.reason);
        error.hidden = false;
      }
    });

    // Clear a stale error the moment the reader edits the reference again.
    input.addEventListener("input", () => {
      error.hidden = true;
      error.textContent = "";
    });

    // [LAW:dataflow-not-control-flow] Reveal only now that the one effect is wired.
    document.body.classList.add("compare-ready");
  </script>

  {/*
    [LAW:one-source-of-truth] The TL;DR region carries NO summary content — it is an
    empty mount the client reveals and fills from /api/summarize. The summary is the
    most disposable projection of all (regenerated on demand, never stored authority),
    so nothing about it belongs in the stored paste or in this server render.
    [LAW:dataflow-not-control-flow] `hidden` until JS reveals it: with JavaScript
    disabled the page is byte-identical (an on-demand LLM enrichment is never required
    to read the conversation), and a no-JS viewer never meets a dead Summarize button —
    the same render-hidden-then-reveal move the copy controls make. aria-live announces
    each state transition (loading → summary / error) to assistive tech.
  */}
  <section class="tldr" hidden aria-live="polite" data-slug={slug}></section>

  {outline.length > 0 && (
    <details class="spine-outline">
      <summary class="spine-outline-summary">
        <span class="spine-outline-title">Outline</span>
        <span class="spine-outline-count">{outline.length} turns</span>
      </summary>
      <ol class="spine-outline-list">
        {outline.map((entry) => (
          <li class="spine-outline-item">
            <a class="spine-outline-link" href={`#${entry.anchor}`}>
              <span class="spine-outline-dot" data-role={entry.role} aria-hidden="true"></span>
              <span class="spine-outline-label">{entry.label}</span>
            </a>
          </li>
        ))}
      </ol>
    </details>
  )}

  {/*
    [LAW:dataflow-not-control-flow] The document-scoped "Copy all code" control. Rendered
    only when there IS code to copy — codeExportHtml is "" otherwise, so the section is
    simply absent, never an empty box or a dead button. The button + its hidden payload are
    inert markup; the client script below confirms clipboard support and wires the copy,
    revealing the button (body.copy-all-ready) exactly as the per-code-block copy does.
  */}
  {codeExportHtml && <section class="code-export" set:html={codeExportHtml} />}

  {/*
    [LAW:one-source-of-truth] data-slug is the ONE client-readable slug: a projection of
    the server `slug` (Astro.params), carried on the section every client script here
    already depends on. The scripts read it rather than each re-deriving the slug from
    location.pathname — a second derivation that would drift if the URL scheme ever changed.
  */}
  <section class="conversation" aria-label="Conversation" data-slug={slug} set:html={renderDialogueHtml(dialogue)} />

  <script>
    import { enhanceClampBlocks } from "../clampBlocks";

    // [LAW:one-source-of-truth] The timeline is a *projection of the rendered
    // conversation*, never a second enumeration of turns. It reads the very
    // elements the renderer emitted (each top-level spine node carries
    // data-index/data-kind/data-role), so a marker cannot point at an index the
    // renderer didn't produce.
    //
    // INCLUSION RULE (the one documented decision — [LAW:no-mode-explosion]): the
    // rail markers exactly the conversation SPINE — one marker per top-level node
    // (user/system message + each grouped assistant turn). Detail blocks the
    // disclosure renderer nests *inside* an assistant card — thinking, tool calls,
    // and subagents (with their own recursively-nested steps) — get NO marker and
    // never appear on the rail, at any depth. The reader scans the human↔agent
    // spine here, then dives into any one turn's detail by expanding it. Because
    // the renderer emits data-index ONLY on spine nodes, this rule needs no filter:
    // the selector below structurally cannot pick up a nested detail block.
    //
    // [LAW:effects-at-boundaries] Scroll position, viewport overflow, and
    // "which turn is in view" are facts only the browser holds. The server
    // emitted the content; navigation over it is built here, client-side.
    // [LAW:no-defensive-null-guards] The .conversation section is rendered
    // unconditionally by this page, so its absence is a broken template
    // invariant, not a normal empty case — assert it once, loudly (mirroring the
    // editor mount's must() helper), rather than threading a silent skip through
    // every consumer below. Downstream code gets a typed non-null root.
    const conversation = document.querySelector<HTMLElement>(".conversation");
    if (!conversation) throw new Error("required .conversation section missing");
    const turns = [
      ...conversation.querySelectorAll<HTMLElement>(":scope > [data-index]"),
    ];

    // [LAW:effects-at-boundaries] Clamp long spine prose to a default height with
    // a bottom Expand toggle — a client capability over the rendered conversation,
    // measured here where layout (the only honest source of "does this overflow")
    // lives. The same enhancer runs on the editor preview, so the two surfaces
    // share one behaviour. No-JS leaves the prose fully expanded (this never runs).
    enhanceClampBlocks(conversation);

    // [LAW:one-source-of-truth] The marker's label is the node's derived topic
    // (data-topic) — the SAME text the static outline shows, emitted by the renderer
    // from spineNodeLabel — so hovering a marker and reading the outline row name one
    // turn identically. The per-role word is only a fallback for the impossible case
    // of a node the renderer emitted without a topic; every real spine node carries a
    // non-empty data-topic, so this degrades honestly rather than lying about a turn.
    const roleName: Record<string, string> = {
      user: "User",
      assistant: "Assistant",
      system: "System",
    };
    const markerLabel = (el: HTMLElement): string =>
      el.dataset.topic || roleName[el.dataset.role ?? ""] || "Message";

    const nav = document.createElement("nav");
    nav.className = "minimap";
    nav.id = "minimap";
    nav.setAttribute("aria-label", "Conversation timeline");

    // [LAW:decomposition] On a narrow viewport there is no gutter to hold the
    // fixed rail, so the SAME rail is revealed as a slide-over by a floating
    // toggle, dimmed behind a scrim. The toggle and scrim are part of the minimap
    // part — built and owned here alongside the rail, meaningless without it. On
    // desktop CSS never reveals them; the rail shows in the gutter directly.
    // [LAW:one-type-per-behavior] not a second mobile rail — one rail, two
    // placements that differ only in CSS (gutter vs. panel).
    const toggle = document.createElement("button");
    toggle.type = "button";
    toggle.className = "minimap-toggle";
    toggle.setAttribute("aria-label", "Show conversation timeline");
    toggle.setAttribute("aria-controls", "minimap");
    toggle.setAttribute("aria-expanded", "false");
    // A miniature spine glyph — short/long/short bars — so the control previews
    // the rail it opens. Lengths are CSS (.minimap-toggle-line:nth-child).
    for (let i = 0; i < 3; i++) {
      const line = document.createElement("span");
      line.className = "minimap-toggle-line";
      toggle.appendChild(line);
    }
    const scrim = document.createElement("div");
    scrim.className = "minimap-scrim";
    scrim.setAttribute("aria-hidden", "true");

    // [LAW:one-source-of-truth] The open state lives in ONE place: the body class
    // the CSS reads. aria-expanded is a derived view of it, written here in the
    // single transition owner so the accessible state can never drift from the
    // visual one. [LAW:dataflow-not-control-flow] open is a value; flipping it is
    // the whole behaviour — no JS positions the panel or the scrim.
    const setOpen = (open: boolean): void => {
      document.body.classList.toggle("minimap-open", open);
      toggle.setAttribute("aria-expanded", String(open));
    };

    // One marker per turn, in order. Colour is carried as data-* and mapped to a
    // hue by CSS — no colour logic in JS. The button is the correct interactive
    // semantic, so keyboard activation and focus come for free.
    // [LAW:types-are-the-program] MAX_LINES line-slots exist per marker — the
    // cap is structural, so "more than 5 lines" is unrepresentable rather than
    // defended against. lineFractions is a total function of one value (the
    // turn's rendered height) → a fixed-length array of per-line width fractions
    // in [0,1]. Length is proportional up to KNEE lines, then bends strongly and
    // asymptotically toward MAX_LINES (a real cap the curve never exceeds). The
    // last non-zero entry is the partial final line; the rest are full (1) or
    // unused (0). MIN_FILL keeps the shortest turn a legible stub.
    const MAX_LINES = 5;
    const L_LINE = 130; // rendered px that fills one minimap line
    const KNEE = 3; // lines below which length is proportional
    const SIGMA = 1.25; // bend strength of the approach to MAX_LINES
    const MIN_FILL = 0.22; // shortest turn still shows this fraction of a line
    const lineFractions = (h: number): number[] => {
      const u = h / L_LINE; // proportional line count, unbounded
      const real =
        u <= KNEE
          ? u
          : KNEE + (MAX_LINES - KNEE) * (1 - Math.exp(-(u - KNEE) / SIGMA));
      const count = Math.min(MAX_LINES, Math.max(MIN_FILL, real));
      const full = Math.floor(count);
      // [LAW:single-enforcer] MIN_FILL is the one floor for *every* visible
      // line, not just the first stub: a line slot is either absent (0) or at
      // least MIN_FILL wide — never an invisible sub-pixel sliver that still
      // claims a height slot and jumps the marker at integer boundaries. The
      // fraction a slot can hold is thus 0 ∪ [MIN_FILL, 1], with the open gap
      // unrepresentable.
      const raw = count - full;
      const partial = raw > 0 && raw < MIN_FILL ? MIN_FILL : raw;
      return Array.from({ length: MAX_LINES }, (_, i) =>
        i < full ? 1 : i === full ? partial : 0,
      );
    };

    const markers = new Map<number, HTMLButtonElement>();
    // [LAW:decomposition] The marker and the turn it projects are one part with
    // two faces; keeping the pair lets the geometry pass measure the turn and
    // size its lines without a Map lookup + null guard the construction makes
    // impossible. Each marker owns exactly MAX_LINES line slots, created once;
    // recompute only sets their widths.
    const bars: { el: HTMLElement; lines: HTMLSpanElement[] }[] = [];
    for (const el of turns) {
      const index = Number(el.dataset.index);
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "minimap-marker";
      btn.dataset.kind = el.dataset.kind ?? "";
      if (el.dataset.role) btn.dataset.role = el.dataset.role;
      btn.setAttribute("aria-label", `Jump to ${markerLabel(el)}`);
      // [LAW:no-ambient-temporal-coupling] Native smooth scroll; the browser
      // owns the animation lifecycle — no rAF loop, no easing timer of ours.
      btn.addEventListener("click", () => {
        el.scrollIntoView({ behavior: "smooth", block: "start" });
        // On mobile the rail is a slide-over; jumping dismisses it so the reader
        // lands on the destination. On desktop minimap-open is never set, so this
        // is a no-op — one handler, no per-viewport branch.
        setOpen(false);
      });
      const lines = Array.from({ length: MAX_LINES }, () => {
        const line = document.createElement("span");
        line.className = "minimap-line";
        btn.appendChild(line);
        return line;
      });
      nav.appendChild(btn);
      markers.set(index, btn);
      bars.push({ el, lines });
    }
    document.body.appendChild(nav);
    document.body.appendChild(toggle);
    document.body.appendChild(scrim);

    // [LAW:no-ambient-temporal-coupling] IntersectionObserver is the browser's
    // owner of "is this turn on screen" — not a scroll handler we debounce. We
    // keep a derived set of intersecting indices and recompute the active marker
    // as a pure function of it (top-most visible turn wins). The rootMargin
    // biases "active" toward the turn entering the upper viewport.
    const visible = new Set<number>();
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          const i = Number((e.target as HTMLElement).dataset.index);
          e.isIntersecting ? visible.add(i) : visible.delete(i);
        }
        const active = visible.size ? Math.min(...visible) : -1;
        for (const [i, btn] of markers) btn.classList.toggle("is-active", i === active);
        // The active marker's resting scale is part of the genie channel, so a
        // change in which turn is active must re-derive scales.
        kick();
      },
      { rootMargin: "-12% 0px -78% 0px" },
    );
    for (const el of turns) io.observe(el);

    // [LAW:dataflow-not-control-flow] The genie is a dock-style magnification
    // lens: every marker's horizontal scale is a pure function of its distance
    // from the pointer. On each move EVERY marker is rescaled — the value
    // (distance) varies, never *whether* a marker is touched, so there is no
    // "which one is hovered" branch. "No pointer" is the value -Infinity, for
    // which the same bell returns 1, so absence needs no guard.
    // [LAW:effects-at-boundaries] Pointer position is browser-only; the lens is
    // driven here and writes the one --genie channel CSS reads.
    const GENIE_PEAK = 1.7; // scaleX of the marker directly under the pointer
    const GENIE_SIGMA = 44; // px spread of the lens (≈ how many neighbours bulge)
    const ACTIVE_REST = 1.24; // scaleX the in-view marker holds with no pointer
    let pointerY = -Infinity;
    const genieScale = (centerY: number): number => {
      const d = centerY - pointerY;
      const bell = Math.exp(-(d * d) / (2 * GENIE_SIGMA * GENIE_SIGMA));
      return 1 + (GENIE_PEAK - 1) * bell;
    };

    // [LAW:no-ambient-temporal-coupling] Marker centres are read once per layout
    // change (the rail is position:fixed, so scaleX never moves them vertically),
    // not in the hot pointer path. The lens then writes from this cache, keeping
    // reads and writes unbatched-free: measure on layout, write on frame. `cur`
    // is the marker's *displayed* scale, carried across re-measures (read back
    // from the channel it owns) so a layout change never snaps the lens.
    type Center = { btn: HTMLButtonElement; y: number; cur: number };
    let centers: Center[] = [];
    const measureCenters = (): void => {
      centers = [...markers.values()].map((btn) => {
        const r = btn.getBoundingClientRect();
        return { btn, y: r.top + r.height / 2, cur: Number(btn.style.getPropertyValue("--genie")) || 1 };
      });
    };

    // [LAW:no-ambient-temporal-coupling] rAF is the SINGLE timing authority for
    // the lens — there is no CSS transition on the scale. Each frame eases every
    // marker's displayed scale toward its target (max of its resting scale and
    // the pointer bell), and the loop keeps running until every marker has
    // settled. One owner animates both the grab (toward the pointer) and the
    // release (pointer gone → target falls back to rest): a CSS transition would
    // be a second clock fighting these per-frame writes and lagging fast sweeps.
    const EASE = 0.35; // per-frame approach fraction toward target
    const SETTLED = 0.002; // |target − cur| below which the marker is at rest
    let raf = 0;
    const tick = (): void => {
      let moving = false;
      for (const c of centers) {
        const rest = c.btn.classList.contains("is-active") ? ACTIVE_REST : 1;
        const target = Math.max(rest, genieScale(c.y));
        const next = c.cur + (target - c.cur) * EASE;
        c.cur = Math.abs(target - next) < SETTLED ? target : next;
        c.btn.style.setProperty("--genie", c.cur.toFixed(3));
        if (c.cur !== target) moving = true;
      }
      raf = moving ? requestAnimationFrame(tick) : 0;
    };
    const kick = (): void => {
      if (!raf) raf = requestAnimationFrame(tick);
    };

    // [LAW:effects-at-boundaries] Pointer position is browser-only; the listeners
    // only record it (or its absence) and wake the loop. pointercancel covers the
    // touch/stylus case where the browser steals the gesture and never fires
    // pointerleave — without it the lens would freeze mid-bulge.
    nav.addEventListener("pointermove", (e) => {
      pointerY = e.clientY;
      kick();
    });
    const release = (): void => {
      pointerY = -Infinity;
      kick();
    };
    nav.addEventListener("pointerleave", release);
    nav.addEventListener("pointercancel", release);
    // The rail itself scrolls when it overflows; that moves marker centres.
    nav.addEventListener("scroll", () => {
      measureCenters();
      kick();
    });
    // Prime the cache synchronously so the lens is live on the very first
    // pointer event, not coupled to the first async layout callback.
    measureCenters();

    // [LAW:effects-at-boundaries] Open/close is user intent — from the toggle,
    // the scrim, a jump (above), or Escape — all routed through the one setOpen
    // owner. Opening lays out the until-now display:none rail for the first time,
    // so re-measure marker centres before the genie's first touch-drag reads them.
    toggle.addEventListener("click", () => {
      const willOpen = !document.body.classList.contains("minimap-open");
      setOpen(willOpen);
      // Opening lays out the until-now display:none rail; remeasure AND wake the
      // lens so every marker eases to its current-geometry target (the active
      // marker's resting magnification, or any marker the rail's last close left
      // mid-scale) instead of reappearing stale. Mirrors recompute()'s measure-
      // then-kick — the rAF loop is the one timing authority for the scale.
      if (willOpen) {
        measureCenters();
        kick();
      }
    });
    scrim.addEventListener("click", () => setOpen(false));
    window.addEventListener("keydown", (e) => {
      if (e.key === "Escape") setOpen(false);
    });

    // [LAW:dataflow-not-control-flow] Degradation is a value transition, not a
    // branch that skips building the rail: the timeline is shown iff the page
    // overflows the viewport — the exact condition under which jumping to
    // off-screen turns has any value. No magic turn-count threshold. ResizeObserver
    // owns content-size changes (images, fonts, reflow); window resize owns
    // viewport changes; both feed the one derived boolean.
    // [LAW:no-ambient-temporal-coupling] One owner recomputes everything that
    // depends on layout: the overflow boolean and the length-derived bar sizes.
    // [LAW:effects-at-boundaries] measuring rendered height is browser-only —
    // all reads happen first, then all writes, so we never interleave a read
    // after a write and force a synchronous reflow per bar.
    const recompute = (): void => {
      const overflows =
        document.documentElement.scrollHeight > window.innerHeight + 4;
      document.body.classList.toggle("has-timeline", overflows);

      const fractions = bars.map(({ el }) =>
        lineFractions(el.getBoundingClientRect().height),
      );
      bars.forEach(({ lines }, i) => {
        lines.forEach((line, j) => {
          const f = fractions[i]![j]!;
          // A zero-width slot is removed from the flow so it adds neither height
          // nor gap; otherwise the line shows its fraction of the full width.
          line.style.display = f > 0 ? "block" : "none";
          line.style.width = `${(f * 100).toFixed(1)}%`;
        });
      });
      // Line widths just changed marker heights → centres moved; re-measure and
      // wake the lens to ease toward the new geometry from the same layout pass.
      measureCenters();
      kick();
    };
    new ResizeObserver(recompute).observe(document.documentElement);
    window.addEventListener("resize", recompute);
    recompute();

    // [LAW:effects-at-boundaries] The clipboard is browser-only state; the copy
    // affordance is wired here, not on the server. [LAW:one-source-of-truth] each
    // button copies its block's <code> textContent — the exact bytes rendered —
    // so the copied text can never drift from what the viewer sees.
    //
    // navigator.clipboard is a genuine capability discriminant: absent it (old
    // browser, insecure origin) the buttons stay hidden rather than promising an
    // action they can't deliver. Revealing them is one value flip, not a branch
    // that conditionally builds the affordance.
    if (navigator.clipboard) {
      // [LAW:one-source-of-truth] The permalink is derived from the rendered anchor
      // the server emitted (el.id, e.g. "t3"), never a re-encoding of the "#t"+index
      // scheme — so a copied URL cannot drift from the id the browser honors for
      // fragment navigation. Both per-turn controls read the link through this.
      const permalinkOf = (el: HTMLElement): string =>
        location.origin + location.pathname + "#" + el.id;

      // [LAW:one-source-of-truth] The quoted text is a prose block's rendered text,
      // read from the DOM the renderer emitted — but stripped of the interactive
      // CHROME the renderer also puts INSIDE prose. A code block carries a "Copy"
      // button and a language tag; the reader does not read those as content, so a
      // quote that includes them drifts from what is on screen. They are hidden for
      // the single innerText read (which forces layout but no paint — nothing
      // flickers), then restored: the same measure-by-transient-toggle pattern
      // clampBlocks uses. innerText (not textContent) keeps paragraph breaks, and
      // with the chrome gone a <pre>'s own whitespace (code indentation) survives.
      // Only leading/trailing blank LINES are stripped — never spaces, which would
      // eat a code block's indentation.
      const proseText = (src: HTMLElement): string => {
        const chrome = [
          ...src.querySelectorAll<HTMLElement>(".copy-code, .code-lang"),
        ];
        const restore = chrome.map((c) => c.style.display);
        for (const c of chrome) c.style.display = "none";
        try {
          return src.innerText.replace(/^\n+/, "").replace(/\n+$/, "");
        } finally {
          chrome.forEach((c, i) => (c.style.display = restore[i]!));
        }
      };

      // [LAW:one-source-of-truth] A quote is the turn's OWN rendered prose plus its
      // permalink — read from the DOM the renderer emitted, never a re-serialization,
      // so it can't drift from what the reader sees. Spine prose only: every
      // .bubble-body NOT nested inside a collapsed detail (thinking/tool-call/
      // subagent) — the readable moment of the turn, not its folded machinery. The
      // prose sits in .clamp-content when a block is clampable (whose wrapper also
      // holds the Show-more toggle, which reading .clamp-content skips), else in the
      // body itself.
      const buildQuote = (el: HTMLElement): string => {
        const prose = [...el.querySelectorAll<HTMLElement>(".bubble-body")]
          .filter((b) => !b.closest(".condensed"))
          .map((b) =>
            proseText(b.querySelector<HTMLElement>(":scope > .clamp-content") ?? b),
          )
          .filter((t) => t.trim() !== "")
          .join("\n\n");
        // [LAW:dataflow-not-control-flow] The blockquote is a VALUE derived from the
        // prose, not a branch that skips formatting: one return, the data decides its
        // shape. Empty prose (a turn with no readable text — e.g. only tool calls) maps
        // to an empty string, so the result is the bare permalink — never a lone '>'
        // marker quoting nothing. Present prose becomes blockquote lines (a blank line
        // → a bare '>', so a multi-paragraph quote stays one blockquote) plus the
        // separator; the formatter only touches non-empty prose, so it never emits the
        // empty marker.
        const quoted = prose
          ? prose.split("\n").map((line) => (line ? "> " + line : ">")).join("\n") +
            "\n\n"
          : "";
        return quoted + permalinkOf(el);
      };

      // [LAW:one-type-per-behavior] copy-link and quote are ONE control type — a
      // clipboard pill that flips to "Copied" then reverts — differing only in label
      // and in the value copied. The payload is a thunk read at click time, so it
      // reflects the live DOM (current prose, current permalink), never a value
      // snapshotted at build. [LAW:effects-at-boundaries] the click is the only
      // world-touch; the button owns its own revert timer, no shared scheduler.
      const clipboardControl = (
        label: string,
        ariaLabel: string,
        payload: () => string,
      ): HTMLButtonElement => {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.className = "turn-control";
        btn.setAttribute("aria-label", ariaLabel);
        btn.textContent = label;
        btn.addEventListener("click", async () => {
          await navigator.clipboard.writeText(payload());
          btn.classList.add("copied");
          btn.textContent = "Copied";
          window.setTimeout(() => {
            btn.classList.remove("copied");
            btn.textContent = label;
          }, 1200);
        });
        return btn;
      };

      // [LAW:effects-at-boundaries] The controls are a browser capability built here
      // over the same `turns` the minimap projects — one navigational contract
      // [LAW:one-source-of-truth], never a second enumeration. The cluster is
      // absolute-positioned (CSS), so it adds no height and never perturbs the
      // minimap's length measurement; both controls sit within it, so neither
      // hardcodes an offset past the other.
      for (const el of turns) {
        const controls = document.createElement("div");
        controls.className = "turn-controls";
        controls.appendChild(
          clipboardControl("Copy link", "Copy link to this turn", () =>
            permalinkOf(el),
          ),
        );
        controls.appendChild(
          clipboardControl("Quote", "Quote this turn", () => buildQuote(el)),
        );
        el.appendChild(controls);
      }
      document.body.classList.add("permalink-ready");

      for (const btn of document.querySelectorAll<HTMLButtonElement>(
        "pre.code-block > .copy-code",
      )) {
        const code = btn.parentElement?.querySelector("code");
        // [LAW:no-silent-failure] render.ts always emits <code> inside the <pre>,
        // so a missing sibling here is a broken template invariant, not a normal
        // empty case — fail loudly rather than skip this button into silence.
        if (!code) throw new Error("copy-code button has no sibling <code>");
        // [LAW:one-source-of-truth] The revert text is read from the button the
        // server rendered, never re-typed here, so the label can't drift from
        // render.ts.
        const label = btn.textContent;
        btn.addEventListener("click", async () => {
          await navigator.clipboard.writeText(code.textContent ?? "");
          btn.classList.add("copied");
          btn.textContent = "Copied";
          // The button owns its own revert timer — no shared scheduler.
          window.setTimeout(() => {
            btn.classList.remove("copied");
            btn.textContent = label;
          }, 1200);
        });
      }
      document.body.classList.add("code-copy-ready");

      // [LAW:effects-at-boundaries] The document-scoped "Copy all code" control. One
      // button copies the server-built payload of every extracted artifact. The payload
      // is rendered ONCE into a hidden sibling <pre> (server-escaped; textContent decodes
      // it back verbatim), so the button carries no copy of the data and the clipboard
      // bytes equal the server projection [LAW:one-source-of-truth] — the same read-from-
      // sibling shape .copy-code uses. [LAW:dataflow-not-control-flow] the button's absence
      // is a value: with no code the server emitted no control, so this query finds nothing
      // and the block stays inert (body.copy-all-ready is never added, so nothing reveals).
      const copyAll = document.querySelector<HTMLButtonElement>(".copy-all-code");
      if (copyAll) {
        const payloadEl = copyAll.parentElement?.querySelector(".copy-all-code-payload");
        // [LAW:no-silent-failure] The control renderer always emits the payload <pre>
        // beside the button, so a missing sibling is a broken template invariant, not a
        // normal empty case — fail loudly rather than copy an empty string into silence.
        if (!payloadEl) throw new Error("copy-all-code button has no payload sibling");
        // [LAW:one-source-of-truth] Revert label read from the button the server rendered.
        const label = copyAll.textContent;
        // [LAW:no-ambient-temporal-coupling] ONE revert timer owns the label. A rapid
        // second click clears the first timer before arming its own, so an earlier timer
        // can never flip the label back out from under a later "Copied".
        let revert = 0;
        copyAll.addEventListener("click", async () => {
          await navigator.clipboard.writeText(payloadEl.textContent ?? "");
          copyAll.classList.add("copied");
          copyAll.textContent = "Copied";
          window.clearTimeout(revert);
          revert = window.setTimeout(() => {
            copyAll.classList.remove("copied");
            copyAll.textContent = label;
          }, 1200);
        });
        document.body.classList.add("copy-all-ready");
      }

      // [LAW:effects-at-boundaries] A degraded subagent (data-subagent-degraded)
      // renders a "Copy agent prompt" button; clicking it copies a slug-keyed
      // prompt that tells a coding agent — running in the repo where THIS session
      // ran — to send the missing subagents/agent-*.jsonl to /api/augment. The
      // server validates session membership and rejects foreign lines loudly, so
      // the recipe is safe to run blindly. [LAW:one-source-of-truth] slug is read from
      // the one server-rendered data-slug on .conversation (already queried above), not
      // re-derived from location — origin is a genuine browser fact and stays from location.
      const slug = conversation.dataset.slug ?? "";
      const apiOrigin = location.origin;
      const pasteUrl = apiOrigin + "/" + slug;
      // Built as line strings (not a template literal) so the bash ${...} inside
      // the recipe is literal, not JS interpolation. slug/origin are injected as
      // JSON literals where they land inside the shell snippet.
      const backfillPrompt = [
        "The shared paste at " + pasteUrl + " is missing the nested transcripts",
        "for one or more subagents from this Claude Code session. Send the missing",
        "subagent transcripts so the paste can render them in full.",
        "",
        "Run this from the repo where the original session ran (resume that session",
        "if needed so $CLAUDE_CODE_SESSION_ID points at it). It locates this",
        "session's subagent files and POSTs them to the paste's augment endpoint:",
        "",
        "```bash",
        "set -euo pipefail",
        ': "${CLAUDE_CODE_SESSION_ID:?run inside the Claude Code session that produced the paste}"',
        "proj=\"$(pwd | sed 's|[/.]|-|g')\"",
        'subdir="$HOME/.claude/projects/$proj/$CLAUDE_CODE_SESSION_ID/subagents"',
        "python3 -c '",
        "import json, sys, glob, os",
        "subdir = sys.argv[1]",
        'files = sorted(glob.glob(os.path.join(subdir, "agent-*.jsonl")))',
        'if not files:',
        '    sys.exit("no subagent transcripts found in " + subdir)',
        // Fold each group's sibling agent-<id>.meta.json {agentType, description}
        // onto its first real sidechain line, so an orphan subagent keeps its type
        // through augment. setdefault never clobbers an existing field; the line
        // already has agentId+isSidechain+sessionId, so it passes the validator.
        "def fold_meta(text, meta_path):",
        "    if not os.path.exists(meta_path):",
        "        return text",
        "    try:",
        '        meta = json.load(open(meta_path, encoding="utf-8"))',
        "    except Exception as e:",
        // [LAW:no-silent-failure] An absent sidecar is the norm (handled above);
        // an EXISTING file that won't read/parse is an anomaly — surface it loudly
        // before degrading to the honest null type, never swallow it silently.
        '        sys.stderr.write("backfill: WARNING: could not read " + meta_path + " (" + str(e) + "); orphan will render untyped\\n")',
        "        return text",
        '    fields = {k: meta[k] for k in ("agentType", "description") if isinstance(meta.get(k), str) and meta[k]}',
        "    if not fields:",
        "        return text",
        '    out = text.split("\\n")',
        "    for i, raw in enumerate(out):",
        "        if not raw.strip():",
        "            continue",
        "        try:",
        "            obj = json.loads(raw)",
        "        except Exception:",
        "            continue",
        '        if isinstance(obj, dict) and obj.get("agentId") and obj.get("isSidechain") is True:',
        "            for k, v in fields.items():",
        "                obj.setdefault(k, v)",
        "            out[i] = json.dumps(obj, ensure_ascii=False)",
        "            break",
        '    return "\\n".join(out)',
        'parts = [fold_meta(open(p, encoding="utf-8", errors="replace").read(), p[:-len(".jsonl")] + ".meta.json") for p in files]',
        'content = "\\n".join(parts)',
        "sys.stdout.write(json.dumps({\"slug\": " + JSON.stringify(slug) + ", \"content\": content}))",
        "' \"$subdir\" | curl -sS --fail-with-body -X POST " +
          JSON.stringify(apiOrigin + "/api/augment") +
          " -H 'content-type: application/json' --data-binary @-",
        "```",
        "",
        "The endpoint rejects any line that doesn't belong to this paste's session,",
        "so it is safe to run. When it succeeds, reload " + pasteUrl + " — the",
        "subagents will show their full nested transcripts.",
      ].join("\n");

      for (const btn of document.querySelectorAll<HTMLButtonElement>(
        ".subagent-degraded > .copy-agent-prompt",
      )) {
        // [LAW:one-source-of-truth] Revert label read from the rendered button.
        const label = btn.textContent;
        btn.addEventListener("click", async () => {
          await navigator.clipboard.writeText(backfillPrompt);
          btn.classList.add("copied");
          btn.textContent = "Copied — paste into a coding agent";
          window.setTimeout(() => {
            btn.classList.remove("copied");
            btn.textContent = label;
          }, 1600);
        });
      }
      document.body.classList.add("agent-prompt-ready");
    }

    // [LAW:effects-at-boundaries] The document-scoped "Download as files" control, wired
    // at SCRIPT level — NOT inside the clipboard `if` above — because the download has no
    // clipboard dependency: it decodes base64, wraps a Blob, and clicks a transient
    // <a download>. Its own capability seam is URL.createObjectURL, so on an insecure
    // origin (no navigator.clipboard) the download still wires while the copy pills stay
    // hidden [LAW:no-silent-failure — each affordance declares the capability it needs].
    // The server built the reconstructed file tree into a zip and embedded it base64 in
    // the button's hidden sibling <pre> [LAW:one-source-of-truth]; this only PERFORMS the
    // effect. [LAW:dataflow-not-control-flow] the button's absence is a value: with no
    // code the server emitted no control, this query finds nothing, nothing reveals.
    const downloadAll = document.querySelector<HTMLButtonElement>(".download-all-code");
    if (downloadAll && typeof URL.createObjectURL === "function") {
      const zipPayloadEl = downloadAll.parentElement?.querySelector(".download-all-code-payload");
      // [LAW:no-silent-failure] The control renderer always emits the payload <pre> beside
      // the button, so a missing sibling is a broken template invariant, not a normal empty
      // case — fail loudly rather than download an empty archive in silence.
      if (!zipPayloadEl) throw new Error("download-all-code button has no payload sibling");
      const zipBase64 = zipPayloadEl.textContent ?? "";
      // [LAW:one-source-of-truth] Filename slug read from the one server-rendered data-slug
      // on the .conversation element already resolved above, not re-queried or re-derived
      // from location.
      const zipName = "slopspot-" + (conversation.dataset.slug ?? "paste") + "-code.zip";
      // [LAW:one-source-of-truth] Revert label read from the button the server rendered.
      const zipLabel = downloadAll.textContent;
      // [LAW:no-ambient-temporal-coupling] ONE revert timer owns the label; a rapid second
      // click clears the first before arming its own.
      let zipRevert = 0;
      downloadAll.addEventListener("click", () => {
        // atob -> binary string -> the exact archive bytes the server encoded.
        const binary = atob(zipBase64);
        const bytes = new Uint8Array(binary.length);
        for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
        const url = URL.createObjectURL(new Blob([bytes], { type: "application/zip" }));
        const a = document.createElement("a");
        a.href = url;
        a.download = zipName;
        a.click();
        // Revoke on the next macrotask: the click has initiated the download by the time
        // this fires, so the URL is freed without cancelling it in Firefox/Safari.
        window.setTimeout(() => URL.revokeObjectURL(url), 0);
        downloadAll.classList.add("downloaded");
        downloadAll.textContent = "Downloaded";
        window.clearTimeout(zipRevert);
        zipRevert = window.setTimeout(() => {
          downloadAll.classList.remove("downloaded");
          downloadAll.textContent = zipLabel;
        }, 1200);
      });
      document.body.classList.add("download-ready");
    }
  </script>

  <script>
    // [LAW:decomposition] The TL;DR enrichment is its own part, cut apart from the
    // minimap/copy script above: it owns exactly the on-demand summary region and
    // shares nothing with navigation. [LAW:effects-at-boundaries] the summary is a
    // network fact the browser fetches on demand; the server emitted only an empty
    // mount, and this is the single edge that talks to /api/summarize.
    //
    // [LAW:no-defensive-null-guards] The page renders .tldr unconditionally, so its
    // absence is a broken template invariant — assert once, loudly (as the minimap
    // mount does), never thread a silent skip.
    const region = document.querySelector<HTMLElement>(".tldr");
    if (!region) throw new Error("required .tldr region missing");
    const slug = region.dataset.slug ?? "";

    // [LAW:types-are-the-program] The region's total state is a discriminated union —
    // every screen it can show is one representable value, so "loading with a live
    // button" or "ready with no summary" are unrepresentable rather than defended
    // against. The loading state carries NO control, which is what makes a double
    // Regenerate structurally impossible: setState swaps the button out of the DOM
    // before the in-flight fetch resolves, so there is no in-flight boolean to track
    // [LAW:no-ambient-temporal-coupling].
    type TldrState =
      | { kind: "idle" }
      | { kind: "loading" }
      | { kind: "ready"; summary: string; cached: boolean }
      | { kind: "error"; reason: string };

    const makeButton = (
      className: string,
      label: string,
      onClick: () => void,
    ): HTMLButtonElement => {
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = className;
      btn.textContent = label;
      btn.addEventListener("click", onClick);
      return btn;
    };

    // [LAW:effects-at-boundaries] The one network edge. [LAW:dataflow-not-control-flow]
    // Regenerate vs. first-summarize is a single value — `force` — that rides the query
    // (?force=1), the same directive resolveSummary reads to bypass the cache read. The
    // fetch always posts {slug}; only the value of force differs.
    const generate = async (force: boolean): Promise<void> => {
      render({ kind: "loading" });
      const url = "/api/summarize" + (force ? "?force=1" : "");
      const res = await fetch(url, {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ slug }),
      }).catch(() => null);
      // [LAW:no-silent-failure] A dropped connection is a visible error with a reason,
      // never a silent return that leaves the reader staring at a spinner forever.
      if (!res) {
        render({ kind: "error", reason: "Network error — could not reach the summarizer." });
        return;
      }
      const body = (await res.json().catch(() => null)) as
        | { summary?: string; cached?: boolean; error?: string }
        | null;
      if (res.ok && typeof body?.summary === "string") {
        render({ kind: "ready", summary: body.summary, cached: body.cached === true });
        return;
      }
      // [LAW:no-silent-failure] Surface the server's own reason — the 503 not-configured
      // message, a 502 provider failure, a 410 expired — so a failure is legible, never a
      // blank region. Only if the body carried none do we fall back to the bare status.
      render({ kind: "error", reason: body?.error ?? `Summarize failed (HTTP ${res.status}).` });
    };

    // [LAW:dataflow-not-control-flow] The region's markup is a pure projection of the
    // state value: one exhaustive switch, rebuilt whole on every transition. A new
    // state kind is compiler-forced to add its arm (the Node[] return leaves no
    // implicit fall-through). The summary and error text are inserted as textContent,
    // never innerHTML — the summary is plain prose by the system-prompt contract, and
    // textContent means even a misbehaving model can never inject markup here.
    const tldrChildren = (s: TldrState): Node[] => {
      switch (s.kind) {
        case "idle":
          return [
            makeButton("tldr-btn tldr-trigger", "TL;DR — summarize this conversation", () =>
              void generate(false),
            ),
          ];
        case "loading": {
          const status = document.createElement("div");
          status.className = "tldr-status";
          status.textContent = "Summarizing…";
          return [status];
        }
        case "ready": {
          const head = document.createElement("div");
          head.className = "tldr-head";
          const label = document.createElement("span");
          label.className = "tldr-label";
          label.textContent = "TL;DR";
          // [LAW:one-source-of-truth] Regenerate re-derives past the cache; the same
          // control both times, differing only in the `force` value it carries.
          head.appendChild(label);
          head.appendChild(makeButton("tldr-btn tldr-regen", "Regenerate", () => void generate(true)));
          const p = document.createElement("p");
          p.className = "tldr-body";
          p.textContent = s.summary;
          return [head, p];
        }
        case "error": {
          const box = document.createElement("div");
          box.className = "tldr-error";
          box.setAttribute("role", "alert");
          const msg = document.createElement("span");
          msg.className = "tldr-error-msg";
          msg.textContent = s.reason;
          box.appendChild(msg);
          box.appendChild(makeButton("tldr-btn tldr-retry", "Try again", () => void generate(false)));
          return [box];
        }
      }
    };

    const render = (s: TldrState): void => {
      region.replaceChildren(...tldrChildren(s));
    };

    // Reveal the until-now hidden mount and seat it in the idle state. A no-JS viewer
    // never reaches here, so the region stays display:none and the page is unchanged.
    region.hidden = false;
    render({ kind: "idle" });
  </script>

  <script>
    // [LAW:decomposition] The overlay authoring editor is its own part, cut apart from the
    // minimap/copy and TL;DR scripts: it owns exactly the owner's overlay authoring and
    // shares nothing with reader navigation. It is INERT for every reader — it touches
    // neither the DOM nor the network until the owner opts into edit mode (#edit) — so the
    // public page stays byte-identical and carries zero authoring chrome. A per-turn kind
    // selector authors all three directive kinds — hide (whole/span), collapse, feature.
    //
    // [LAW:single-enforcer] "Are you the owner?" is answered by the ONE auth gate, never a
    // second per-paste scheme: GET /api/overlay is admin-gated middleware, so a 200 both
    // proves the viewer is the owner AND returns the authoritative current directive set to
    // prefill. On save the owner POSTs the COMPLETE desired set (empty = clear) and the page
    // RELOADS — the server's deriveViewableDialogue re-renders the applied overlay on BOTH
    // /<slug> and /<slug>/t<N>, so this client never re-implements redaction (that second
    // renderer would be a source of truth that drifts from the server's).

    // [LAW:types-are-the-program] The client's mirror of the server OverlayDirective union
    // (types.ts). It must be the FULL union, not a hide-turn narrowing: opening the editor on
    // a paste that already carries span redactions, collapses, or features must ROUND-TRIP
    // them on Save. A narrower type would coerce every stored directive to a whole-turn hide
    // on re-emit — silently coarsening spans and dropping collapse/feature the owner never
    // touched [LAW:no-silent-failure]. Only `hide` reaches sub-turn spans; collapse/feature
    // address whole turns (TurnTarget), exactly as the server type.
    type TurnTarget = { kind: "turn"; index: number };
    type OverlayTarget =
      | TurnTarget
      | { kind: "span"; index: number; piece: number; start: number; end: number };
    type OverlayDirective =
      | { kind: "hide"; target: OverlayTarget }
      | { kind: "collapse"; target: TurnTarget }
      | { kind: "feature"; target: TurnTarget };

    const EDIT_HASH = "#edit";

    const makeEl = <K extends keyof HTMLElementTagNameMap>(
      tag: K,
      className: string,
    ): HTMLElementTagNameMap[K] => {
      const el = document.createElement(tag);
      el.className = className;
      return el;
    };

    // Edit mode activates once per load: the first time the owner is in #edit. Kept active
    // across later hash changes (no teardown) — Exit navigates to the clean pathname, which
    // reloads out of edit mode entirely.
    let active = false;

    // [LAW:single-enforcer] Exit always leaves edit mode the same way: a full server
    // re-render of the public view (applied overlay, zero authoring chrome). Assigning the
    // bare pathname would differ from /<slug>#edit only in the fragment — a same-document
    // navigation that does NOT reload — so strip the hash with replaceState first, then
    // reload to force the fresh render. No client teardown that could leave chrome behind.
    const exitButton = (): HTMLButtonElement => {
      const exit = makeEl("button", "overlay-editor-exit");
      exit.type = "button";
      exit.textContent = "Exit";
      exit.addEventListener("click", () => {
        history.replaceState(null, "", location.pathname);
        location.reload();
      });
      return exit;
    };

    // [LAW:decomposition] Mounting the fixed bar and reserving body space for it are one
    // concern — the bar's PRESENCE — kept apart from edit mode (which reveals toggles and
    // hides the reader copy controls, owner-only). Both the editor bar and the notice bar
    // are fixed at the bottom, so both need the clearance; only the owner path additionally
    // adds overlay-editing. overlay-bar-present owns the padding for either bar.
    const mountBar = (bar: HTMLElement): void => {
      document.body.appendChild(bar);
      document.body.classList.add("overlay-bar-present");
    };

    // A minimal notice bar — a message and an Exit, nothing else — shown when the probe
    // denies or fails. [LAW:no-silent-failure] a non-owner who types #edit gets a legible
    // dead-end, but WITHOUT the overlay-editing class, so their reader copy controls are
    // never hidden. Deliberately NOT the editor bar: no Redact title, no Save, no toggles.
    const showNotice = (message: string): void => {
      const bar = makeEl("div", "overlay-editor-bar");
      bar.setAttribute("role", "region");
      bar.setAttribute("aria-label", "Overlay editor");
      const status = makeEl("span", "overlay-editor-status");
      status.setAttribute("aria-live", "polite");
      status.textContent = message;
      bar.appendChild(status);
      bar.appendChild(exitButton());
      mountBar(bar);
    };

    const activate = async (): Promise<void> => {
      if (active || location.hash !== EDIT_HASH) return;
      active = true;

      // [LAW:one-source-of-truth] slug is read from the one server-rendered data-slug on
      // .conversation — the SAME element whose spine nodes are the editable turns below —
      // never re-derived from location.pathname. [LAW:no-defensive-null-guards] .conversation
      // is rendered unconditionally, so its absence is a broken template invariant: assert
      // once, loudly, and every use below gets a typed non-null root.
      const conversation = document.querySelector<HTMLElement>(".conversation");
      if (!conversation) throw new Error("required .conversation section missing");
      const slug = conversation.dataset.slug ?? "";

      // [LAW:no-ambient-temporal-coupling] Probe the admin gate BEFORE any chrome touches the
      // DOM — the reveal is gated on the result VALUE, never on execution order. So a
      // non-owner who types #edit never sees editor chrome flash and never loses their reader
      // controls; only a confirmed owner (200, with the current directives) gets the editor.
      const res = await fetch("/api/overlay?slug=" + encodeURIComponent(slug), {
        headers: { accept: "application/json" },
      }).catch(() => null);
      const body = res
        ? ((await res.json().catch(() => null)) as
            | { directives?: OverlayDirective[]; pieces?: string[][]; spineHtml?: string; error?: string }
            | null)
        : null;

      // [LAW:dataflow-not-control-flow] The probe outcome is a value that selects what to
      // build: a denial/error yields only a notice (reader view untouched); success yields
      // the full editor. [LAW:no-silent-failure] every non-owner / network / server outcome
      // is a legible message, never a silent no-op. spineHtml is required — without the
      // unfiltered spine a feature paste would hide the turns the owner must whitelist.
      if (
        !res ||
        !res.ok ||
        !Array.isArray(body?.directives) ||
        !Array.isArray(body?.pieces) ||
        typeof body?.spineHtml !== "string"
      ) {
        showNotice(
          !res
            ? "Network error — could not reach the overlay endpoint."
            : res.status === 401
              ? "Not the owner — sign in via /sloppy to author redactions."
              : (body?.error ?? `Could not load overlay (HTTP ${res.status}).`),
        );
        return;
      }

      // [LAW:no-silent-failure] Validate the authoring spine BEFORE mutating the DOM. The spine
      // and body.pieces are two projections of the SAME server deriveDialogue(turns) — span
      // authoring is leak-safe ONLY while pieces[index] aligns with the DOM node at that index.
      // Parse the spineHtml OFF the live DOM (a detached <template>) and count its top-level
      // turns; on a mismatch (a drifted renderer, a truncated response), bail to the notice bar
      // with the reader view STILL INTACT — the swap below never runs — rather than destroy the
      // reader DOM and then discover the spine is unusable. The else is meaningful (a legible
      // dead-end), not a silent skip.
      const parsedSpine = document.createElement("template");
      parsedSpine.innerHTML = body.spineHtml;
      const spineTurnCount = [...parsedSpine.content.children].filter((el) => el.hasAttribute("data-index")).length;
      if (spineTurnCount !== body.pieces.length) {
        showNotice("The editor could not load: the authoring spine drifted from its source. Reload and try again.");
        return;
      }

      // [LAW:single-enforcer] Validated — swap the reader's server-rendered spine for the
      // UNFILTERED authoring spine (editSpine, admin-gated). The public render applies the
      // overlay, and a FEATURE overlay OMITS non-featured turns, so the reader DOM has only the
      // featured turns — the per-turn controls below (built from ':scope > [data-index]') would
      // then cover only those, and the owner could never whitelist a hidden turn. Swapping in
      // every turn makes them all selectable; Exit reloads the applied (filtered) view. The
      // same `conversation` element is reused (only its children change), so its data-slug and
      // every reference above stay valid. [LAW:one-source-of-truth] pieces[index] aligns with
      // this spine by construction — both derive from the same full deriveDialogue(turns).
      conversation.innerHTML = body.spineHtml;

      // Owner confirmed — build the editor bar. The reader-degrading overlay-editing class
      // (which hides the copy controls and reveals the per-turn controls) is added only at the
      // end of this success path, never before auth.
      const bar = makeEl("div", "overlay-editor-bar");
      bar.setAttribute("role", "region");
      bar.setAttribute("aria-label", "Overlay editor");
      const title = makeEl("span", "overlay-editor-title");
      title.textContent = "Overlay";
      const status = makeEl("span", "overlay-editor-status");
      status.setAttribute("aria-live", "polite");
      const save = makeEl("button", "overlay-editor-save");
      save.type = "button";
      save.textContent = "Save overlay";
      for (const child of [title, status, save, exitButton()]) bar.appendChild(child);
      mountBar(bar);

      // [LAW:types-are-the-program] A turn's authored display directive — ONE kind per turn:
      // a WHOLE-turn hide, a set of sub-turn span hides (a refinement of hide), a collapse, or
      // a feature. These are mutually exclusive by construction, mirroring the per-turn KIND
      // selector: the editor holds one directive per turn, so "hidden AND collapsed" is not a
      // state it can express (the machinery could, but the authoring surface is single-kind).
      type SpanRange = { piece: number; start: number; end: number };
      type TurnDirective =
        | { kind: "hide" }
        | { kind: "spans"; spans: SpanRange[] }
        | { kind: "collapse" }
        | { kind: "feature" };

      // [LAW:one-source-of-truth] State seeds from the stored directives the gate returned —
      // never re-derived from the redacted DOM (a hidden turn shows only "[redacted]" there).
      // ONE store now: `byTurn` holds every authored kind (hide/spans/collapse/feature) — no
      // blind passthrough, because the editor now authors every kind [LAW:no-silent-failure].
      // `pieces` is the leak-proof coordinate space from the server — pieces[index][p] is the
      // EXACT raw source a span's offsets index into.
      //
      // [LAW:dataflow-not-control-flow] Folding the flat directive list into one kind per turn
      // is order-independent via a precedence RANK: a well-formed editor-authored overlay has
      // one kind per turn (faithful round-trip), and a hand-authored overlay with several kinds
      // on one turn NORMALIZES to the highest-ranked — VISIBLE in the selector before Save, not
      // a silent drop. whole-hide is the redaction superset (> spans, matching displayPlan);
      // redaction outranks feature (whitelist) outranks collapse (fold).
      const KIND_RANK: Record<TurnDirective["kind"], number> = { hide: 4, spans: 3, feature: 2, collapse: 1 };
      const byTurn = new Map<number, TurnDirective>();
      const seed = (index: number, candidate: TurnDirective): void => {
        const cur = byTurn.get(index);
        // Two span directives on one turn accumulate (same kind, same rank) rather than one
        // replacing the other. [LAW:effects-at-boundaries] spread, never in-place push.
        if (cur?.kind === "spans" && candidate.kind === "spans") {
          byTurn.set(index, { kind: "spans", spans: [...cur.spans, ...candidate.spans] });
          return;
        }
        if (cur === undefined || KIND_RANK[candidate.kind] > KIND_RANK[cur.kind]) byTurn.set(index, candidate);
      };
      const pieces = body.pieces;
      for (const d of body.directives) {
        if (d.kind === "collapse") seed(d.target.index, { kind: "collapse" });
        else if (d.kind === "feature") seed(d.target.index, { kind: "feature" });
        else if (d.target.kind === "turn") seed(d.target.index, { kind: "hide" });
        else {
          const t = d.target;
          seed(t.index, { kind: "spans", spans: [{ piece: t.piece, start: t.start, end: t.end }] });
        }
      }

      // Which turns' span panels are open — a UI-only projection, not authored state.
      const expanded = new Set<number>();

      // [LAW:no-silent-failure] Resolve the current selection to a span, or a LEGIBLE reason
      // it could not. Offsets are exact ONLY when both endpoints are the SAME raw piece's lone
      // text node: textContent minted exactly one Text child per piece, so startOffset/endOffset
      // are then character indices into that verbatim source string — never a rendered-DOM offset
      // needing a silent remap that could miss the secret. A selection spanning pieces, or
      // touching non-piece chrome, is rejected loudly rather than mis-captured.
      const captureSelectedSpan = (
        pieceEls: ReadonlyArray<{ el: HTMLElement; piece: number }>,
      ): SpanRange | string => {
        const sel = window.getSelection();
        if (!sel || sel.rangeCount === 0 || sel.isCollapsed) {
          return "Select the text to redact inside a raw piece below.";
        }
        const range = sel.getRangeAt(0);
        const match = pieceEls.find(({ el }) => el.firstChild === range.startContainer);
        if (
          match === undefined ||
          range.startContainer !== range.endContainer ||
          range.startContainer.nodeType !== Node.TEXT_NODE
        ) {
          return "Keep the selection inside a single raw piece.";
        }
        const start = Math.min(range.startOffset, range.endOffset);
        const end = Math.max(range.startOffset, range.endOffset);
        if (start >= end) return "Empty selection — nothing to redact.";
        return { piece: match.piece, start, end };
      };

      // [LAW:dataflow-not-control-flow] Every mutator changes the state VALUE then re-renders;
      // none touches the DOM directly — render is the one projection of state to chrome.
      // setKind is the per-turn selector's whole effect: "none" clears the turn; every other
      // value sets that single directive. "hide" is the WHOLE-turn redaction — spans are reached
      // by refining a hide in the span panel (addSpan), so the selector reads "hide" for both.
      const setKind = (index: number, kind: "none" | "hide" | "collapse" | "feature"): void => {
        if (kind === "none") byTurn.delete(index);
        else byTurn.set(index, { kind });
        render();
      };
      // A span refines a hide into sub-turn redaction: whole → spans, or append to an existing
      // span set. [LAW:single-enforcer] The guard states the SAME hide-ish contract the span
      // panel's visibility uses (render below) — positively, so it cannot drift: a span refines
      // ONLY a hide/spans turn. Enumerating the forbidden kinds instead would leave a gap (an
      // unset turn), silently minting a span the owner never picked "Hide" for [LAW:no-silent-failure].
      const addSpan = (index: number, span: SpanRange): void => {
        const existing = byTurn.get(index);
        if (existing?.kind !== "hide" && existing?.kind !== "spans") return;
        const spans = existing.kind === "spans" ? [...existing.spans, span] : [span];
        byTurn.set(index, { kind: "spans", spans });
        render();
      };
      // Removing the last span reverts the turn to a WHOLE hide (still hide-ish), never to
      // "none" — the owner chose hide via the selector; emptying the span set narrows the
      // redaction back to the whole turn rather than un-hiding it.
      const removeSpan = (index: number, at: number): void => {
        const existing = byTurn.get(index);
        if (existing?.kind !== "spans") return;
        const spans = existing.spans.filter((_, i) => i !== at);
        byTurn.set(index, spans.length === 0 ? { kind: "hide" } : { kind: "spans", spans });
        render();
      };

      // [LAW:one-source-of-truth] The editable turns are the SAME spine enumeration the minimap
      // and permalink controls project — top-level nodes carrying data-index — never a second
      // list. data-index IS the overlay target index (t<N>), so a control here names exactly the
      // node applyOverlay and the /t<N> permalink address; pieces[index] is that node's raw prose.
      const turns = [...conversation.querySelectorAll<HTMLElement>(":scope > [data-index]")];

      // [LAW:one-type-per-behavior] The four kinds are one selector, differing only in value —
      // none/hide/collapse/feature map 1:1 to the directive kinds (hide→whole-turn hide; spans
      // refine hide in the panel below). "Show" is the none label — the turn shows unchanged.
      const KIND_OPTIONS = [
        { value: "none", label: "Show" },
        { value: "hide", label: "Hide" },
        { value: "collapse", label: "Collapse" },
        { value: "feature", label: "Feature" },
      ] as const;

      const controls = turns.map((el) => {
        const index = Number(el.dataset.index);
        const holder = makeEl("div", "overlay-turn-control");
        // [LAW:no-ambient-temporal-coupling] Plain DOM <select>: setting .value in render is
        // reliable here (the lit-html cold-render `.value` gotcha applies only to lit-html's
        // declarative binding, not to a createElement'd select whose options exist eagerly).
        const select = makeEl("select", "overlay-kind-select");
        for (const opt of KIND_OPTIONS) {
          const option = document.createElement("option");
          option.value = opt.value;
          option.textContent = opt.label;
          select.appendChild(option);
        }
        select.addEventListener("change", () =>
          setKind(index, select.value as "none" | "hide" | "collapse" | "feature"),
        );
        holder.appendChild(select);
        el.appendChild(holder);

        // A turn with no span-addressable prose (only a tool call, say) yields an empty pieces
        // array — its redaction can only be a whole hide, so it grows no span chrome. The presence
        // of pieces is a value that decides whether the span UI exists, not a guard hiding a bug.
        // [LAW:types-are-the-program] The span chrome is ONE nullable field, not four parallel
        // nullables — so "toggle present but panel absent" is unrepresentable; render narrows once.
        const turnPieces = pieces[index] ?? [];
        if (turnPieces.length === 0) {
          return { el, index, select, span: null };
        }

        const spanToggle = makeEl("button", "overlay-span-toggle");
        spanToggle.type = "button";
        spanToggle.textContent = "Redact part…";
        spanToggle.addEventListener("click", () => {
          expanded.has(index) ? expanded.delete(index) : expanded.add(index);
          render();
        });
        holder.appendChild(spanToggle);

        const panel = makeEl("div", "overlay-span-panel");
        const hint = makeEl("p", "overlay-span-hint");
        hint.textContent = "Select the exact text to redact, then Redact selection.";
        panel.appendChild(hint);
        // [LAW:one-source-of-truth] Each raw piece is its verbatim source string set as
        // textContent — exactly one Text node, so a selection's offsets ARE source offsets.
        const pieceEls = turnPieces.map((text, piece) => {
          const pieceEl = makeEl("div", "overlay-raw-piece");
          pieceEl.dataset.piece = String(piece);
          pieceEl.textContent = text;
          panel.appendChild(pieceEl);
          return { el: pieceEl, piece };
        });
        const addRow = makeEl("div", "overlay-span-addrow");
        const add = makeEl("button", "overlay-span-add");
        add.type = "button";
        add.textContent = "Redact selection";
        const msg = makeEl("span", "overlay-span-msg");
        msg.setAttribute("aria-live", "polite");
        add.addEventListener("click", () => {
          const result = captureSelectedSpan(pieceEls);
          if (typeof result === "string") {
            msg.textContent = result;
            return;
          }
          msg.textContent = "";
          window.getSelection()?.removeAllRanges();
          addSpan(index, result);
        });
        addRow.appendChild(add);
        addRow.appendChild(msg);
        panel.appendChild(addRow);
        const spanList = makeEl("div", "overlay-span-list");
        panel.appendChild(spanList);
        el.appendChild(panel);

        return { el, index, select, span: { toggle: spanToggle, panel, list: spanList } };
      });

      // [LAW:dataflow-not-control-flow] The whole editor surface is a pure projection of the
      // state: each turn's selector value/pending class, its span panel visibility and list, the
      // feature-whitelist marks, and the bar's summary are recomputed from `byTurn`/`expanded`
      // on every change — never mutated incrementally per event.
      const render = (): void => {
        let wholeCount = 0;
        let spanCount = 0;
        let collapseCount = 0;
        let featureCount = 0;
        for (const c of controls) {
          const state = byTurn.get(c.index);
          const kind = state?.kind;
          const isWhole = kind === "hide";
          const spans = state?.kind === "spans" ? state.spans : [];
          const isHideish = kind === "hide" || kind === "spans";
          if (isWhole) wholeCount += 1;
          spanCount += spans.length;
          if (kind === "collapse") collapseCount += 1;
          if (kind === "feature") featureCount += 1;

          // The selector shows "hide" for both whole and spans (spans is a refinement of hide);
          // an unset turn shows "none". Plain-DOM .value assignment, reliable on cold render.
          c.select.value = kind === "spans" ? "hide" : (kind ?? "none");

          c.el.classList.toggle("overlay-pending-hide", isWhole);
          c.el.classList.toggle("overlay-pending-spans", spans.length > 0);
          c.el.classList.toggle("overlay-pending-collapse", kind === "collapse");
          c.el.classList.toggle("overlay-pending-feature", kind === "feature");

          // The span panel refines a hide — available only when the turn is hide-ish. On any
          // other kind the "Redact part…" toggle is hidden and its panel closed.
          if (c.span) {
            c.span.toggle.hidden = !isHideish;
            const open = expanded.has(c.index) && isHideish;
            c.span.toggle.setAttribute("aria-expanded", String(open));
            c.span.panel.hidden = !open;
            c.span.list.replaceChildren(
              ...spans.map((s, i) => {
                const item = makeEl("div", "overlay-span-item");
                const coord = makeEl("span", "overlay-span-coord");
                coord.textContent = `piece ${s.piece} · chars ${s.start}–${s.end}`;
                const rm = makeEl("button", "overlay-span-remove");
                rm.type = "button";
                rm.textContent = "Remove";
                rm.addEventListener("click", () => removeSpan(c.index, i));
                item.appendChild(coord);
                item.appendChild(rm);
                return item;
              }),
            );
          }
        }

        // [LAW:dataflow-not-control-flow] Feature is a WHITELIST: the PRESENCE of any feature
        // directive flips the paste to show-ONLY-featured. Make that legible — mark the body so
        // non-featured turns visibly read as excluded from the reel (CSS dims them + notes it).
        // featureCount === 0 ⇒ no reel, show all, so every mark clears. This is the one
        // non-obvious UX the epic flagged: a single feature hides every other turn.
        const hasFeature = featureCount > 0;
        document.body.classList.toggle("overlay-has-feature", hasFeature);
        for (const c of controls) {
          c.el.classList.toggle(
            "overlay-reel-excluded",
            hasFeature && byTurn.get(c.index)?.kind !== "feature",
          );
        }

        const summary: string[] = [];
        if (wholeCount > 0) summary.push(`${wholeCount} turn${wholeCount === 1 ? "" : "s"} hidden`);
        if (spanCount > 0) summary.push(`${spanCount} span${spanCount === 1 ? "" : "s"}`);
        if (collapseCount > 0) summary.push(`${collapseCount} collapsed`);
        if (hasFeature) {
          summary.push(`reel: ${featureCount} turn${featureCount === 1 ? "" : "s"} shown, rest hidden`);
        }
        status.textContent = summary.length === 0 ? "No overlay" : summary.join(" · ");
      };

      // [LAW:one-source-of-truth] The COMPLETE directive set to persist, folded from the one
      // per-turn state: whole → turn-target hide, spans → span-target hides, collapse/feature →
      // whole-turn directives. Order is irrelevant (displayPlan folds it), so emit in turn order
      // for a stable, legible write. No passthrough — the editor authors every kind, so nothing
      // is held blind [LAW:no-silent-failure]. The switch is exhaustive: a new TurnDirective
      // kind is compiler-forced to declare how it serializes.
      const emitDirectives = (): OverlayDirective[] => {
        const out: OverlayDirective[] = [];
        for (const [index, d] of [...byTurn.entries()].sort((a, b) => a[0] - b[0])) {
          switch (d.kind) {
            case "hide":
              out.push({ kind: "hide", target: { kind: "turn", index } });
              break;
            case "spans":
              for (const s of d.spans) {
                out.push({ kind: "hide", target: { kind: "span", index, piece: s.piece, start: s.start, end: s.end } });
              }
              break;
            case "collapse":
              out.push({ kind: "collapse", target: { kind: "turn", index } });
              break;
            case "feature":
              out.push({ kind: "feature", target: { kind: "turn", index } });
              break;
            default: {
              // [LAW:no-silent-failure] `setKind` reaches this fold through an `as` cast of
              // select.value, so a cast violation (a stray option, DOM tampering) could store an
              // unrecognized kind. Pin exhaustiveness at compile time (`_never`) AND fail loudly
              // at runtime, mirroring overlay.ts's assertNever — a dropped directive is never silent.
              const _never: never = d;
              throw new Error(`emitDirectives: unhandled TurnDirective kind: ${String((_never as { kind: string }).kind)}`);
            }
          }
        }
        return out;
      };

      // [LAW:effects-at-boundaries] Save is the one world-touch: POST the COMPLETE desired
      // directive set (an empty array is the valid "clear all redactions" write), then let
      // the server be the renderer — reload so it re-derives the applied overlay here and on
      // the /t<N> permalink. #edit is preserved by reload, so the editor reopens showing the
      // now-applied state.
      const performSave = async (): Promise<void> => {
        const directives = emitDirectives();
        save.disabled = true;
        status.textContent = "Saving…";
        const saveRes = await fetch("/api/overlay", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ slug, directives }),
        }).catch(() => null);
        if (saveRes?.ok) {
          location.reload();
          return;
        }
        // [LAW:no-silent-failure] Surface the server's own reason (a 422 out-of-range, a 401
        // expired session) so a failed save is legible, never a silent no-op.
        save.disabled = false;
        if (!saveRes) {
          status.textContent = "Network error — not saved.";
          return;
        }
        const errBody = (await saveRes.json().catch(() => null)) as { error?: string } | null;
        status.textContent = errBody?.error ?? `Save failed (HTTP ${saveRes.status}).`;
      };
      save.addEventListener("click", () => void performSave());

      // Reveal the editing chrome — toggles shown, reader copy controls hidden — only now,
      // after the owner is confirmed. Before this line the page is the untouched reader view.
      document.body.classList.add("overlay-editing");
      render();
    };

    window.addEventListener("hashchange", () => void activate());
    void activate();
  </script>
</Base>
