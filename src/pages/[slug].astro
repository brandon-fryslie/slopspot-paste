---
import { env } from "cloudflare:workers";
import Base from "../layouts/Base.astro";
import { renderTurnsHtml } from "../renderTurns";
import { getConversation } from "../storage";
import { isValidSlug } from "../slug";
import { PLATFORM_LABEL, platformOf, sourceOf, sourceUrlOf, viewLifetime, isHiddenFromPublic } from "../types";

export const prerender = false;

const { slug } = Astro.params;

// [LAW:dataflow-not-control-flow] Same handler shape: validate slug → fetch →
// render. Variability is the conversation value or its absence.
if (!slug || !isValidSlug(slug)) {
  return new Response("Not found", { status: 404 });
}

const conversation = await getConversation(env.PASTES, slug);

if (!conversation) {
  return new Response("This paste has expired or never existed.", { status: 404 });
}

// [LAW:single-enforcer] isHiddenFromPublic is the one gate for soft-deleted and
// naturally-expired pastes. 410 Gone distinguishes "it existed but is gone" from
// 404 "never existed" — HTTP semantics for the tombstone state.
if (isHiddenFromPublic(conversation, Date.now())) {
  return new Response("This paste has expired or been deleted.", { status: 410 });
}

const title = conversation.title ?? "Shared conversation";
// [LAW:dataflow-not-control-flow] Both lifetime cases produce a meta string
// through one match — a pinned paste reads "Never disappears", never a forgotten
// branch that lies "Disappears in 0 days".
const life = viewLifetime(conversation.lifetime, Date.now());
const lifetimeLabel =
  life.kind === "pinned"
    ? "Never disappears"
    : `Disappears in ${life.days} ${life.days === 1 ? "day" : "days"}`;
// [LAW:one-source-of-truth] Platform is a projection of the captured origin —
// source is derived via sourceOf, then platform from that, here once and carried
// as data: the body attribute themes the page via CSS variables; the label names
// the platform in the meta line. A generic platform has a null label, so absence
// of provenance renders as absence.
const origin = conversation.origin;
const platform = platformOf(sourceOf(origin));
const platformLabel = PLATFORM_LABEL[platform];
// [LAW:one-source-of-truth] The original-source link is a projection of the
// captured origin (sourceUrlOf), never a second stored field. null for every
// origin without an upstream URL — text pastes, editor-authored, legacy — which
// renders as nothing below, not a placeholder ([LAW:dataflow-not-control-flow]:
// the absence is a value the template skips, not a branch that conditionally
// builds a header). The URL was validated as a claude.ai/share link at ingest.
const sourceUrl = sourceUrlOf(origin);
---

<Base title={`${title} · slopspot paste`} platform={platform}>
  <section class="conversation-header">
    <h1>{title}</h1>
    <p class="conversation-meta">
      {platformLabel && <span class="platform-badge">{platformLabel}</span>}
      {platformLabel && <span aria-hidden="true">·</span>}
      <span>{conversation.turns.length} turns</span>
      <span aria-hidden="true">·</span>
      <span>{lifetimeLabel}</span>
    </p>
    {sourceUrl && (
      <p class="source-origin">
        <a href={sourceUrl} target="_blank" rel="noopener noreferrer">
          View original on claude.ai ↗
        </a>
      </p>
    )}
  </section>

  <section class="conversation" aria-label="Conversation" set:html={renderTurnsHtml(conversation.turns)} />

  <script>
    // [LAW:one-source-of-truth] The timeline is a *projection of the rendered
    // conversation*, never a second enumeration of turns. It reads the very
    // elements renderTurns emitted (each carries data-index/data-kind/data-role),
    // so a marker cannot point at an index the renderer didn't produce.
    //
    // [LAW:effects-at-boundaries] Scroll position, viewport overflow, and
    // "which turn is in view" are facts only the browser holds. The server
    // emitted the content; navigation over it is built here, client-side.
    const conversation = document.querySelector<HTMLElement>(".conversation");
    const turns = conversation
      ? [...conversation.querySelectorAll<HTMLElement>(":scope > [data-index]")]
      : [];

    // aria-label text per kind — a value→string map, not a behaviour branch.
    const roleName: Record<string, string> = {
      user: "User",
      assistant: "Assistant",
      system: "System",
    };
    const markerLabel = (el: HTMLElement): string => {
      const kind = el.dataset.kind ?? "turn";
      if (kind === "message") return roleName[el.dataset.role ?? ""] ?? "Message";
      if (kind === "tool-call") return el.dataset.tool ?? "Tool call";
      if (kind === "turn-summary") return "Summary";
      return kind.charAt(0).toUpperCase() + kind.slice(1);
    };

    const nav = document.createElement("nav");
    nav.className = "minimap";
    nav.setAttribute("aria-label", "Conversation timeline");

    // One marker per turn, in order. Colour is carried as data-* and mapped to a
    // hue by CSS — no colour logic in JS. The button is the correct interactive
    // semantic, so keyboard activation and focus come for free.
    // [LAW:types-are-the-program] MAX_LINES line-slots exist per marker — the
    // cap is structural, so "more than 5 lines" is unrepresentable rather than
    // defended against. lineFractions is a total function of one value (the
    // turn's rendered height) → a fixed-length array of per-line width fractions
    // in [0,1]. Length is proportional up to KNEE lines, then bends strongly and
    // asymptotically toward MAX_LINES (a real cap the curve never exceeds). The
    // last non-zero entry is the partial final line; the rest are full (1) or
    // unused (0). MIN_FILL keeps the shortest turn a legible stub.
    const MAX_LINES = 5;
    const L_LINE = 130; // rendered px that fills one minimap line
    const KNEE = 3; // lines below which length is proportional
    const SIGMA = 1.25; // bend strength of the approach to MAX_LINES
    const MIN_FILL = 0.22; // shortest turn still shows this fraction of a line
    const lineFractions = (h: number): number[] => {
      const u = h / L_LINE; // proportional line count, unbounded
      const real =
        u <= KNEE
          ? u
          : KNEE + (MAX_LINES - KNEE) * (1 - Math.exp(-(u - KNEE) / SIGMA));
      const count = Math.min(MAX_LINES, Math.max(MIN_FILL, real));
      const full = Math.floor(count);
      // [LAW:single-enforcer] MIN_FILL is the one floor for *every* visible
      // line, not just the first stub: a line slot is either absent (0) or at
      // least MIN_FILL wide — never an invisible sub-pixel sliver that still
      // claims a height slot and jumps the marker at integer boundaries. The
      // fraction a slot can hold is thus 0 ∪ [MIN_FILL, 1], with the open gap
      // unrepresentable.
      const raw = count - full;
      const partial = raw > 0 && raw < MIN_FILL ? MIN_FILL : raw;
      return Array.from({ length: MAX_LINES }, (_, i) =>
        i < full ? 1 : i === full ? partial : 0,
      );
    };

    const markers = new Map<number, HTMLButtonElement>();
    // [LAW:decomposition] The marker and the turn it projects are one part with
    // two faces; keeping the pair lets the geometry pass measure the turn and
    // size its lines without a Map lookup + null guard the construction makes
    // impossible. Each marker owns exactly MAX_LINES line slots, created once;
    // recompute only sets their widths.
    const bars: { el: HTMLElement; lines: HTMLSpanElement[] }[] = [];
    for (const el of turns) {
      const index = Number(el.dataset.index);
      const btn = document.createElement("button");
      btn.type = "button";
      btn.className = "minimap-marker";
      btn.dataset.kind = el.dataset.kind ?? "";
      if (el.dataset.role) btn.dataset.role = el.dataset.role;
      btn.setAttribute("aria-label", `Jump to ${markerLabel(el)}`);
      // [LAW:no-ambient-temporal-coupling] Native smooth scroll; the browser
      // owns the animation lifecycle — no rAF loop, no easing timer of ours.
      btn.addEventListener("click", () =>
        el.scrollIntoView({ behavior: "smooth", block: "start" }),
      );
      const lines = Array.from({ length: MAX_LINES }, () => {
        const line = document.createElement("span");
        line.className = "minimap-line";
        btn.appendChild(line);
        return line;
      });
      nav.appendChild(btn);
      markers.set(index, btn);
      bars.push({ el, lines });
    }
    document.body.appendChild(nav);

    // [LAW:no-ambient-temporal-coupling] IntersectionObserver is the browser's
    // owner of "is this turn on screen" — not a scroll handler we debounce. We
    // keep a derived set of intersecting indices and recompute the active marker
    // as a pure function of it (top-most visible turn wins). The rootMargin
    // biases "active" toward the turn entering the upper viewport.
    const visible = new Set<number>();
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          const i = Number((e.target as HTMLElement).dataset.index);
          e.isIntersecting ? visible.add(i) : visible.delete(i);
        }
        const active = visible.size ? Math.min(...visible) : -1;
        for (const [i, btn] of markers) btn.classList.toggle("is-active", i === active);
        // The active marker's resting scale is part of the genie channel, so a
        // change in which turn is active must re-derive scales.
        scheduleGenie();
      },
      { rootMargin: "-12% 0px -78% 0px" },
    );
    for (const el of turns) io.observe(el);

    // [LAW:dataflow-not-control-flow] The genie is a dock-style magnification
    // lens: every marker's horizontal scale is a pure function of its distance
    // from the pointer. On each move EVERY marker is rescaled — the value
    // (distance) varies, never *whether* a marker is touched, so there is no
    // "which one is hovered" branch. "No pointer" is the value -Infinity, for
    // which the same bell returns 1, so absence needs no guard.
    // [LAW:effects-at-boundaries] Pointer position is browser-only; the lens is
    // driven here and writes the one --genie channel CSS reads.
    const GENIE_PEAK = 1.7; // scaleX of the marker directly under the pointer
    const GENIE_SIGMA = 44; // px spread of the lens (≈ how many neighbours bulge)
    const ACTIVE_REST = 1.24; // scaleX the in-view marker holds with no pointer
    let pointerY = -Infinity;
    const genieScale = (centerY: number): number => {
      const d = centerY - pointerY;
      const bell = Math.exp(-(d * d) / (2 * GENIE_SIGMA * GENIE_SIGMA));
      return 1 + (GENIE_PEAK - 1) * bell;
    };

    // [LAW:no-ambient-temporal-coupling] Marker centres are read once per layout
    // change (the rail is position:fixed, so scaleX never moves them vertically),
    // not in the hot pointer path. The lens then writes from this cache, keeping
    // reads and writes unbatched-free: measure on layout, write on move.
    let centers: { btn: HTMLButtonElement; y: number }[] = [];
    const measureCenters = (): void => {
      centers = [...markers.values()].map((btn) => {
        const r = btn.getBoundingClientRect();
        return { btn, y: r.top + r.height / 2 };
      });
    };
    const applyGenie = (): void => {
      for (const { btn, y } of centers) {
        const rest = btn.classList.contains("is-active") ? ACTIVE_REST : 1;
        btn.style.setProperty("--genie", Math.max(rest, genieScale(y)).toFixed(3));
      }
    };

    // [LAW:no-ambient-temporal-coupling] rAF is the frame owner; pointer events
    // only record intent and request a frame, so a burst of moves collapses to
    // one rescale per frame rather than one per event.
    let frame = 0;
    const scheduleGenie = (): void => {
      if (frame) return;
      frame = requestAnimationFrame(() => {
        frame = 0;
        applyGenie();
      });
    };
    nav.addEventListener("pointermove", (e) => {
      pointerY = e.clientY;
      scheduleGenie();
    });
    nav.addEventListener("pointerleave", () => {
      pointerY = -Infinity;
      scheduleGenie();
    });
    // The rail itself scrolls when it overflows; that moves marker centres.
    nav.addEventListener("scroll", () => {
      measureCenters();
      scheduleGenie();
    });

    // [LAW:dataflow-not-control-flow] Degradation is a value transition, not a
    // branch that skips building the rail: the timeline is shown iff the page
    // overflows the viewport — the exact condition under which jumping to
    // off-screen turns has any value. No magic turn-count threshold. ResizeObserver
    // owns content-size changes (images, fonts, reflow); window resize owns
    // viewport changes; both feed the one derived boolean.
    // [LAW:no-ambient-temporal-coupling] One owner recomputes everything that
    // depends on layout: the overflow boolean and the length-derived bar sizes.
    // [LAW:effects-at-boundaries] measuring rendered height is browser-only —
    // all reads happen first, then all writes, so we never interleave a read
    // after a write and force a synchronous reflow per bar.
    const recompute = (): void => {
      const overflows =
        document.documentElement.scrollHeight > window.innerHeight + 4;
      document.body.classList.toggle("has-timeline", overflows);

      const fractions = bars.map(({ el }) =>
        lineFractions(el.getBoundingClientRect().height),
      );
      bars.forEach(({ lines }, i) => {
        lines.forEach((line, j) => {
          const f = fractions[i]![j]!;
          // A zero-width slot is removed from the flow so it adds neither height
          // nor gap; otherwise the line shows its fraction of the full width.
          line.style.display = f > 0 ? "block" : "none";
          line.style.width = `${(f * 100).toFixed(1)}%`;
        });
      });
      // Line widths just changed marker heights → centres moved; re-measure and
      // re-derive the lens from the same layout pass that produced them.
      measureCenters();
      applyGenie();
    };
    new ResizeObserver(recompute).observe(document.documentElement);
    window.addEventListener("resize", recompute);
    recompute();

    // [LAW:effects-at-boundaries] The clipboard is browser-only state; the copy
    // affordance is wired here, not on the server. [LAW:one-source-of-truth] each
    // button copies its block's <code> textContent — the exact bytes rendered —
    // so the copied text can never drift from what the viewer sees.
    //
    // navigator.clipboard is a genuine capability discriminant: absent it (old
    // browser, insecure origin) the buttons stay hidden rather than promising an
    // action they can't deliver. Revealing them is one value flip, not a branch
    // that conditionally builds the affordance.
    if (navigator.clipboard) {
      for (const btn of document.querySelectorAll<HTMLButtonElement>(
        "pre.code-block > .copy-code",
      )) {
        const code = btn.parentElement?.querySelector("code");
        // [LAW:no-silent-failure] render.ts always emits <code> inside the <pre>,
        // so a missing sibling here is a broken template invariant, not a normal
        // empty case — fail loudly rather than skip this button into silence.
        if (!code) throw new Error("copy-code button has no sibling <code>");
        // [LAW:one-source-of-truth] The revert text is read from the button the
        // server rendered, never re-typed here, so the label can't drift from
        // render.ts.
        const label = btn.textContent;
        btn.addEventListener("click", async () => {
          await navigator.clipboard.writeText(code.textContent ?? "");
          btn.classList.add("copied");
          btn.textContent = "Copied";
          // The button owns its own revert timer — no shared scheduler.
          window.setTimeout(() => {
            btn.classList.remove("copied");
            btn.textContent = label;
          }, 1200);
        });
      }
      document.body.classList.add("code-copy-ready");
    }
  </script>
</Base>
