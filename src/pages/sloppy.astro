---
import { env } from "cloudflare:workers";
import Base from "../layouts/Base.astro";
import { listConversations } from "../storage";
import { viewLifetime, isHiddenFromPublic, isPurgeable, GRACE_DAYS } from "../types";

export const prerender = false;

// [LAW:locality-or-seam] The admin view is its own route; it doesn't reach
// into the read or write paths or share rendering with [slug].astro. Changes
// here don't ripple into either.
//
// [LAW:dataflow-not-control-flow] One handler shape: fetch the list, render
// the list. An empty list renders as "no pastes" via the same map — no branch
// that skips the table.

const conversations = await listConversations(env.PASTES);
const now = Date.now();
// [LAW:no-silent-failure] /api/purge redirects here with ?purge_errors=N on
// a partial KV failure. Read it once; the banner below surfaces it.
const purgeErrors = Number(Astro.url.searchParams.get("purge_errors") ?? 0);

// Newest first. Sorting in the page (not the storage layer) keeps the storage
// API order-agnostic; other callers can sort however they want.
const rows = [...conversations].sort((a, b) => b.createdAt - a.createdAt);

const liveCount = rows.filter((c) => !isHiddenFromPublic(c, now)).length;
// [LAW:one-source-of-truth] Split by cause of hiding so the admin stats are honest:
// explicitly soft-deleted (deletedAt set) vs. naturally expired (expiresAt past,
// deletedAt null). A fused "tombstoned" count would be a representation that lies.
const deletedCount = rows.filter((c) => c.deletedAt !== null).length;
const expiredCount = rows.filter((c) => c.deletedAt === null && isHiddenFromPublic(c, now)).length;
const purgeableCount = rows.filter((c) => isPurgeable(c, now)).length;

// [LAW:effects-at-boundaries] The viewer's timezone is a fact only the browser
// holds; the Worker cannot know it. So the server emits the canonical epoch
// (data-ms) and a UTC fallback for no-JS; the client script below derives the
// local wall-clock string. This UTC string is the honest fallback only — with
// JS it is replaced in place, so no fixed offset survives for real viewers.
const fmtUtcFallback = (ms: number): string => {
  const d = new Date(ms);
  const yyyy = d.getUTCFullYear();
  const mm = String(d.getUTCMonth() + 1).padStart(2, "0");
  const dd = String(d.getUTCDate()).padStart(2, "0");
  const hh = String(d.getUTCHours()).padStart(2, "0");
  const mi = String(d.getUTCMinutes()).padStart(2, "0");
  return `${yyyy}-${mm}-${dd} ${hh}:${mi}Z`;
};

// [LAW:dataflow-not-control-flow] One render for both lifetime cases: pinned
// shows "∞", expires shows the day count. The pinned arm produces a value, not a
// skipped column.
const fmtLifetime = (c: (typeof rows)[number]): string => {
  const life = viewLifetime(c.lifetime, now);
  return life.kind === "pinned" ? "∞" : `${life.days}d`;
};

const isPinned = (c: (typeof rows)[number]): boolean => c.lifetime.kind === "pinned";

// [LAW:one-source-of-truth] Re-projection only makes sense where the origin can
// replay into turns: a text or share arm. An `editor` origin's turns ARE the
// source (reprojectOrigin returns null for it — re-projecting is a no-op), and a
// null origin has nothing to replay. The affordance's presence is a projection of
// the origin kind, not a separate flag — null/editor rows show none.
const canReproject = (c: (typeof rows)[number]): boolean =>
  c.origin !== null && c.origin.kind !== "editor";

// [LAW:decomposition] Re-fetch is a separate affordance from re-project:
// it hits the network to refresh the stored bytes, then re-derives turns.
// Gate: only url (fetched) origins carry a link to re-fetch against.
// [LAW:one-source-of-truth]: the gate is a projection of the origin kind, not
// a second stored flag.
const canRefetch = (c: (typeof rows)[number]): boolean =>
  c.origin !== null && c.origin.kind === "url";

const previewOf = (c: (typeof rows)[number]): string => {
  const first = c.turns.find((t) => t.kind === "message");
  if (!first) return "";
  const text = (first as { content: string }).content.replace(/\s+/g, " ").trim();
  return text.length > 120 ? text.slice(0, 117) + "…" : text;
};
---

<Base title="sloppy · admin">
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>

  {purgeErrors > 0 && (
    <p class="admin-warning">
      Purge partially failed: {purgeErrors} record{purgeErrors === 1 ? "" : "s"} could not be removed from KV.
      The records still appear below — retry when the issue is resolved.
    </p>
  )}

  <section class="admin-header">
    <h1>All pastes</h1>
    <p class="admin-meta">
      <span>{liveCount} live · {deletedCount} deleted · {expiredCount} expired · {purgeableCount} purgeable</span>
      {purgeableCount > 0 && (
        <form class="purge-form" method="POST" action="/api/purge">
          <button type="submit" class="purge-btn">Purge {purgeableCount} records</button>
        </form>
      )}
    </p>
  </section>

  {rows.length === 0 ? (
    <p class="admin-empty">No pastes yet.</p>
  ) : (
    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th scope="col">Slug</th>
            <th scope="col">Title</th>
            <th scope="col" class="num">Turns</th>
            <th scope="col">Created</th>
            <th scope="col" class="num">Expires</th>
            <th scope="col">Lifetime</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((c) => {
            const hidden = isHiddenFromPublic(c, now);
            return (
              <tr class={hidden ? "row-tombstoned" : ""}>
                <td>
                  {hidden
                    ? <span class="admin-slug admin-slug--dead">{c.slug}</span>
                    : <a class="admin-slug" href={`/${c.slug}`}>{c.slug}</a>
                  }
                  {c.deletedAt !== null && (
                    <div class="tombstone-label">
                      deleted <time class="ts-local" data-ms={c.deletedAt}>{fmtUtcFallback(c.deletedAt)}</time>
                    </div>
                  )}
                </td>
                <td>
                  <div class="admin-title">{c.title ?? "(untitled)"}</div>
                  <div class="admin-preview">{previewOf(c)}</div>
                </td>
                <td class="num">{c.turns.length}</td>
                <td class="ts"><time class="ts-local" data-ms={c.createdAt}>{fmtUtcFallback(c.createdAt)}</time></td>
                <td class="num">{fmtLifetime(c)}</td>
                <td class="lifetime-controls">
                  {!hidden && canReproject(c) && (
                    <form class="reproject-form" method="POST" action="/api/reproject">
                      <input type="hidden" name="slug" value={c.slug} />
                      <button type="submit" class="reproject-btn">Re-project</button>
                    </form>
                  )}
                  {!hidden && canRefetch(c) && (
                    <form class="refetch-form" method="POST" action="/api/refetch">
                      <input type="hidden" name="slug" value={c.slug} />
                      <button type="submit" class="refetch-btn">Re-fetch</button>
                    </form>
                  )}
                  {!hidden && (
                    <>
                      <form class="refresh-form" method="POST" action="/api/refresh">
                        <input type="hidden" name="slug" value={c.slug} />
                        <input type="hidden" name="choice" value="expires" />
                        <button type="submit" class="refresh-btn">Refresh</button>
                      </form>
                      <form class="pin-form" method="POST" action="/api/refresh">
                        <input type="hidden" name="slug" value={c.slug} />
                        <input type="hidden" name="choice" value={isPinned(c) ? "expires" : "pinned"} />
                        <label class="pin-label">
                          <input type="checkbox" class="pin-toggle" checked={isPinned(c)} />
                          <span>auto-refresh</span>
                        </label>
                      </form>
                      <form class="delete-form" method="POST" action="/api/delete">
                        <input type="hidden" name="slug" value={c.slug} />
                        <button type="submit" class="delete-btn">Delete</button>
                      </form>
                    </>
                  )}
                  {hidden && isPurgeable(c, now) && (
                    <span class="purgeable-label">purgeable</span>
                  )}
                  {hidden && !isPurgeable(c, now) && (
                    <span class="grace-label">grace {GRACE_DAYS}d</span>
                  )}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  )}

  <script>
    // [LAW:effects-at-boundaries] The browser is the single authority for the
    // viewer's timezone. Rewrite each canonical epoch (data-ms) into the
    // viewer's local wall clock — same format shape as the server's UTC
    // fallback, local getters instead of getUTC*.
    const pad = (n: number) => String(n).padStart(2, "0");
    for (const el of document.querySelectorAll<HTMLTimeElement>("time.ts-local[data-ms]")) {
      const d = new Date(Number(el.dataset.ms));
      el.textContent = `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}`;
    }

    // [LAW:no-ambient-temporal-coupling] The form already carries the correct
    // target choice (the opposite of the row's current pin state, rendered
    // server-side). Toggling the box just submits that form — a 303 reloads
    // /sloppy with the new state. No client-side state to keep in sync.
    for (const box of document.querySelectorAll<HTMLInputElement>("input.pin-toggle")) {
      box.addEventListener("change", () => box.form?.submit());
    }
  </script>
</Base>
