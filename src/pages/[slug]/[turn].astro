---
import { env } from "cloudflare:workers";
import Base from "../../layouts/Base.astro";
import { deriveViewableDialogue } from "../../overlay";
import { renderTurnCard } from "../../turnCard";
import { loadViewablePaste } from "../../loadPaste";
import { derivePasteMeta } from "../../types";

export const prerender = false;

const { slug, turn } = Astro.params;

// [LAW:single-enforcer] The SAME gate the full page uses — a soft-deleted or expired
// paste is hidden here too, so the card surface cannot leak a paste that is gone on
// /<slug>. [LAW:dataflow-not-control-flow] the result is a value: the conversation or
// the exact response to emit.
const load = await loadViewablePaste(env.PASTES, slug, Date.now());
if (!load.ok) {
  return new Response(load.message, { status: load.status });
}
const conversation = load.conversation;

// [LAW:single-enforcer] The card renders through the SAME renderer the full page uses
// (renderTurnCard → renderDialogueHtml), so a turn drawn as a card cannot drift from
// the same turn in the full conversation. [LAW:no-silent-failure] a non-canonical
// segment or an index past the spine returns null → an honest 404, never a fallback
// to turn 0 or the whole paste. `turn` is always present on this route.
// [LAW:single-enforcer] The card renders the SAME overlay-applied spine the full page
// does (deriveViewableDialogue), so a redacted turn cannot leak through its /t<N>
// permalink while the full page hides it.
const card = renderTurnCard(deriveViewableDialogue(conversation), turn ?? "");
if (card === null) {
  return new Response("Not found", { status: 404 });
}

// [LAW:one-source-of-truth] Title, theme platform, and label are the SAME display-meta
// projection the full page and embed frame show — derived once in derivePasteMeta.
const { title, platform, platformLabel } = derivePasteMeta(conversation);

// [LAW:single-enforcer] One oEmbed discovery <link> makes THIS turn's URL auto-embeddable,
// exactly as the whole-paste page does for /<slug>: a consumer that does oEmbed discovery
// (WordPress, Notion, Discourse) reads this head, finds the endpoint, and calls it — no one
// has to know /api/oembed exists. [LAW:one-source-of-truth] the url= param is the ABSOLUTE
// turn URL (this same /<slug>/t<N>, percent-encoded), which parseEmbedRef resolves back to
// this turn ref, so discovery cannot drift from what the endpoint serves. `turn` is the
// canonical t<N> the route already validated (renderTurnCard returned non-null above), so
// the advertised URL names a real, embeddable turn. We advertise ONLY application/json+oembed
// because the endpoint serves only JSON (501 for xml) and its 200 Content-Type is literally
// this type, so the link's type and the served type agree by construction [FRAMING:
// representation]. Both URLs are absolute (Astro.url.origin — the SAME request-derived origin
// the endpoint computes from new URL(request.url).origin) because consumers fetch cross-origin.
const oembedHref = `${Astro.url.origin}/api/oembed?url=${encodeURIComponent(`${Astro.url.origin}/${slug}/${turn}`)}&format=json`;
---

<Base title={`${title} · one turn · slopspot paste`} platform={platform}>
  <link
    slot="head"
    rel="alternate"
    type="application/json+oembed"
    href={oembedHref}
    title={title}
  />
  <section class="conversation-header">
    <p class="conversation-meta">
      {platformLabel && <span class="platform-badge">{platformLabel}</span>}
      {platformLabel && <span aria-hidden="true">·</span>}
      <span>One turn from</span>
      <a href={`/${slug}#${turn}`}>{title}</a>
    </p>
  </section>

  <section class="conversation" aria-label="Conversation turn" set:html={card} />
</Base>
